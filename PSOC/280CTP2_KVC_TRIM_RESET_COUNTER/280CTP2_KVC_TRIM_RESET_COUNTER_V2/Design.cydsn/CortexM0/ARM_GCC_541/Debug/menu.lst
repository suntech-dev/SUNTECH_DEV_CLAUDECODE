  27:lib/menu.c    **** {
  28:lib/menu.c    ****     static uint16 index=0;
  29:lib/menu.c    ****     
  30:lib/menu.c    ****     if(index >= MAX_MENU_NODE)
  31:lib/menu.c    ****     {
  32:lib/menu.c    ****         printf("Out of Memory : [%d]\r\n", index);
