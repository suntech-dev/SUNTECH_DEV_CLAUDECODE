 301:userMenuCounter.c **** int doSetSubmenu(void *this, uint8 reflash)
 302:userMenuCounter.c **** {
 303:userMenuCounter.c ****     MENUNODE *thisMenu = (MENUNODE *)this;
 304:userMenuCounter.c ****     static MONITORING_MENU menu;
 305:userMenuCounter.c **** 
 306:userMenuCounter.c ****     switch (reflash)
 307:userMenuCounter.c ****     {
 308:userMenuCounter.c ****     case TRUE: // 화면이 바뀔때 실행
 309:userMenuCounter.c ****     {
 310:userMenuCounter.c ****         DisplayDoSetSubmenu(&menu);
 311:userMenuCounter.c ****     }
 312:userMenuCounter.c ****     break;
 313:userMenuCounter.c **** 
 314:userMenuCounter.c ****     case FALSE: // Clicking Check
 315:userMenuCounter.c ****     {
 316:userMenuCounter.c ****         TOUCH tc = GetTouch();
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\cchv9exi.s 			page 20


 317:userMenuCounter.c ****         if (tc.isClick == FALSE)
 318:userMenuCounter.c ****             break;
 319:userMenuCounter.c **** 
 320:userMenuCounter.c ****         switch (getIndexOfClickedButton(&tc, menu.btn, 2))
 321:userMenuCounter.c ****         {
 322:userMenuCounter.c ****         case 0: // Set Target 버튼 클릭
 323:userMenuCounter.c ****             return 0; // 첫 번째 자식 메뉴로 이동 (doTargetInfoMenu)
 324:userMenuCounter.c **** 
 325:userMenuCounter.c ****         case 1: // USB Update 버튼 클릭
 326:userMenuCounter.c ****             return 1; // 두 번째 자식 메뉴로 이동 (doUSBUpdate)
 327:userMenuCounter.c ****         }
 328:userMenuCounter.c **** 
 329:userMenuCounter.c ****         // 하단 버튼 체크
 330:userMenuCounter.c ****         switch (getIndexOfClickedButton(&tc, g_btnBottom, 2))
 331:userMenuCounter.c ****         {
 332:userMenuCounter.c ****         case BOTTOM_LEFT: // EXIT 버튼
 333:userMenuCounter.c ****             return MENU_RETURN_PARENT;
 334:userMenuCounter.c ****         }
 335:userMenuCounter.c ****     }
 336:userMenuCounter.c ****     break;
 337:userMenuCounter.c ****     }
 338:userMenuCounter.c ****     return MENU_RETURN_THIS;
 339:userMenuCounter.c **** }
