 315:lib/manageMenu.c **** void DisplayDoBrigtness(char *title, UP_DOWN_ONE_MENU *menu);
 316:lib/manageMenu.c **** void DisplayDoBrigtnessSelectValue(UP_DOWN_ONE_MENU *menu, uint8 selectIncre, uint16 value);
 317:lib/manageMenu.c **** void DisplayDoBrigtnessValueChange(UP_DOWN_ONE_MENU *menu, uint16 value);
 318:lib/manageMenu.c **** 
 319:lib/manageMenu.c **** int doBrightness(void *this, uint8 reflash)
 320:lib/manageMenu.c **** {
 321:lib/manageMenu.c ****     MENUNODE *thisMenu = (MENUNODE *) this;
 322:lib/manageMenu.c ****     static UP_DOWN_ONE_MENU menu;   
 323:lib/manageMenu.c ****     
 324:lib/manageMenu.c ****     static uint16 selectIncre = 0;
 325:lib/manageMenu.c ****     static uint16 value = 50;
 326:lib/manageMenu.c **** 
 327:lib/manageMenu.c ****     switch(reflash)
 328:lib/manageMenu.c ****     {
 329:lib/manageMenu.c ****         case TRUE: // 화면이 바뀔때 실행
 330:lib/manageMenu.c ****             {                
 331:lib/manageMenu.c ****                 value = getMiscConfig()->uBrightness;
 332:lib/manageMenu.c ****                 
 333:lib/manageMenu.c ****                 DisplayDoBrigtness(thisMenu->nodeName,&menu);
 334:lib/manageMenu.c ****                 DisplayDoBrigtnessSelectValue(&menu, selectIncre, value);
 335:lib/manageMenu.c ****             }
 336:lib/manageMenu.c ****             break;  
 337:lib/manageMenu.c ****         
 338:lib/manageMenu.c ****         case FALSE: // Cliking Check
 339:lib/manageMenu.c ****             {
 340:lib/manageMenu.c **** 
 341:lib/manageMenu.c ****                 TOUCH tc = GetTouch();
 342:lib/manageMenu.c ****                 if(tc.isClick == FALSE) break;
 343:lib/manageMenu.c ****                 uint16 indexClick = getIndexOfClickedButton(&tc, menu.btn,8);
 344:lib/manageMenu.c ****                 switch(indexClick)
 345:lib/manageMenu.c ****                 {                  
 346:lib/manageMenu.c ****                     case 3: // for up
 347:lib/manageMenu.c ****                         if      (value+menu.inc[selectIncre] < 100)
 348:lib/manageMenu.c ****                         {
 349:lib/manageMenu.c ****                             value+=menu.inc[selectIncre];
 350:lib/manageMenu.c ****                             LED_Brightness(value);
 351:lib/manageMenu.c ****                             DisplayDoBrigtnessValueChange(&menu,value);
 352:lib/manageMenu.c ****                         }
 353:lib/manageMenu.c ****                         break;                       
 354:lib/manageMenu.c ****                     case 4: // for down
 355:lib/manageMenu.c ****                         if      (value-menu.inc[selectIncre] > 0)
 356:lib/manageMenu.c ****                         {
 357:lib/manageMenu.c ****                             value-=menu.inc[selectIncre];
 358:lib/manageMenu.c ****                             LED_Brightness(value);
 359:lib/manageMenu.c ****                             DisplayDoBrigtnessValueChange(&menu,value);
 360:lib/manageMenu.c ****                         }
 361:lib/manageMenu.c ****                         break;               
 362:lib/manageMenu.c ****                         break;                        
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccYoDbTb.s 			page 11


 363:lib/manageMenu.c ****                     case 5:
 364:lib/manageMenu.c ****                         selectIncre = 0;
 365:lib/manageMenu.c ****                         DisplayDoBrigtnessSelectValue(&menu,selectIncre, value);                   
 366:lib/manageMenu.c ****                         break;
 367:lib/manageMenu.c ****                     case 6:
 368:lib/manageMenu.c ****                         selectIncre = 1;
 369:lib/manageMenu.c ****                         DisplayDoBrigtnessSelectValue(&menu,selectIncre, value);
 370:lib/manageMenu.c ****                         break;
 371:lib/manageMenu.c ****                     case 7:
 372:lib/manageMenu.c ****                         selectIncre = 2;
 373:lib/manageMenu.c ****                         DisplayDoBrigtnessSelectValue(&menu,selectIncre, value);
 374:lib/manageMenu.c ****                         break;                        
 375:lib/manageMenu.c ****                     default:
 376:lib/manageMenu.c ****                         switch(getIndexOfClickedButton(&tc,g_btnBottom,2))
 377:lib/manageMenu.c ****                         {
 378:lib/manageMenu.c ****                             case BOTTOM_LEFT:
 379:lib/manageMenu.c ****                                 LED_Brightness(getMiscConfig()->uBrightness);
 380:lib/manageMenu.c ****                                 return MENU_RETURN_PARENT;
 381:lib/manageMenu.c ****                             case BOTTOM_RIGHT: 
 382:lib/manageMenu.c ****                             {
 383:lib/manageMenu.c ****                                 getMiscConfig()->uBrightness = value;
 384:lib/manageMenu.c ****                                 LED_Brightness(getMiscConfig()->uBrightness);      
 385:lib/manageMenu.c ****                                 ShowWaitMessage();
 386:lib/manageMenu.c ****                                 SaveExternalFlashConfig();
 387:lib/manageMenu.c ****                                 return MENU_RETURN_PARENT;                                
 388:lib/manageMenu.c ****                             }                            
 389:lib/manageMenu.c ****                         }
 390:lib/manageMenu.c ****                     break;
 391:lib/manageMenu.c ****                 }                                  
 392:lib/manageMenu.c ****             }
 393:lib/manageMenu.c ****             break;
 394:lib/manageMenu.c ****     }
 395:lib/manageMenu.c ****     return MENU_RETURN_THIS;    
 396:lib/manageMenu.c **** }
 397:lib/manageMenu.c **** 
 398:lib/manageMenu.c **** void DisplayDoBrigtness(char *title, UP_DOWN_ONE_MENU *menu)
 399:lib/manageMenu.c **** {
 400:lib/manageMenu.c ****     menu->inc[0] = 1;
 401:lib/manageMenu.c ****     menu->inc[1] = 10;
 402:lib/manageMenu.c ****     menu->inc[2] = 30;
 403:lib/manageMenu.c ****     
 404:lib/manageMenu.c ****     SetDrawUpDownOneMenu(menu, "Bright.", title);
 405:lib/manageMenu.c ****     
 406:lib/manageMenu.c ****     menu->btn[0].disable = TRUE; // for no click title
 407:lib/manageMenu.c ****     menu->btn[1].disable = TRUE; // for no click title
 408:lib/manageMenu.c ****     menu->btn[2].disable = TRUE; // for no click title
 409:lib/manageMenu.c ****     
 410:lib/manageMenu.c ****     SetDrawBottomButtons("QUIT", "SAVE", BUTTON_STYLE_R_GREEN, BUTTON_STYLE_R_BLUE);  
 411:lib/manageMenu.c **** }
 412:lib/manageMenu.c **** 
 413:lib/manageMenu.c **** void DisplayDoBrigtnessSelectValue(UP_DOWN_ONE_MENU *menu, uint8 selectIncre, uint16 value)
 414:lib/manageMenu.c **** {
 415:lib/manageMenu.c ****     menu->btn[5].foregroundColor = ((selectIncre==0) ? ORANGE : DARKGREY);  // 1 incre
 416:lib/manageMenu.c ****     menu->btn[6].foregroundColor = ((selectIncre==1) ? ORANGE : DARKGREY);  // 2 incre  
 417:lib/manageMenu.c ****     menu->btn[7].foregroundColor = ((selectIncre==2) ? ORANGE : DARKGREY);  // 3 incre  
 418:lib/manageMenu.c **** 
 419:lib/manageMenu.c ****     DrawButton(&menu->btn[5]);
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccYoDbTb.s 			page 12


 420:lib/manageMenu.c ****     DrawButton(&menu->btn[6]);
 421:lib/manageMenu.c ****     DrawButton(&menu->btn[7]);
 422:lib/manageMenu.c ****     
 423:lib/manageMenu.c ****     DisplayDoBrigtnessValueChange(menu,value);    
 424:lib/manageMenu.c **** }
 425:lib/manageMenu.c **** 
 426:lib/manageMenu.c **** void DisplayDoBrigtnessValueChange(UP_DOWN_ONE_MENU *menu, uint16 value)
 427:lib/manageMenu.c **** {
 428:lib/manageMenu.c ****     SetButtonText(&menu->btn[2],"%d",value);
 429:lib/manageMenu.c ****     DrawButton(&menu->btn[2]);
 430:lib/manageMenu.c **** }
