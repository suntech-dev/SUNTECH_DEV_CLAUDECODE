 245:lib/widget.c  **** void UpdateDrawListButtons(LIST_MENU *menu, uint16 indexSelect)
 246:lib/widget.c  **** {
 247:lib/widget.c  ****     uint16 yPos;    
 248:lib/widget.c  ****         
 249:lib/widget.c  ****     for(int i=0; i < menu->noOfDisplayButton; i++)
 250:lib/widget.c  ****     {                        
 251:lib/widget.c  ****         int j = i+menu->curPage*menu->noOfDisplayButton;
 252:lib/widget.c  ****         if(j >= menu->sizeOfList) break;
 253:lib/widget.c  ****         
 254:lib/widget.c  ****         BUTTON *btn = &menu->btns[i];
 255:lib/widget.c  ****         
 256:lib/widget.c  ****         if(indexSelect != NO_SELECT)
 257:lib/widget.c  ****         {
 258:lib/widget.c  ****             char buff[30];
 259:lib/widget.c  ****             sprintf(buff,"%c%s",(indexSelect==j) ? '>' : ' ',menu->listText[j]);
 260:lib/widget.c  ****             strcpy(btn->text,buff);              
 261:lib/widget.c  ****         } else {
 262:lib/widget.c  ****             SetButtonText(btn,menu->listText[j]);              
 263:lib/widget.c  ****         }
 264:lib/widget.c  **** 
 265:lib/widget.c  ****         DrawButton(btn);
 266:lib/widget.c  ****         yPos = btn->rect.bottom + 1;
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccS26oY7.s 			page 12


 267:lib/widget.c  ****     }
 268:lib/widget.c  ****     
 269:lib/widget.c  ****     EraseBlankArea(yPos, isExistScroll(menu));
 270:lib/widget.c  **** }
