 303:lib/widget.c  **** int doListMenu(void *this, uint8 reflash) ///////////////////////////////////////////////////////
 304:lib/widget.c  **** /////////////////////////////////////////////////////////////////////////////////////////////////
 305:lib/widget.c  **** {    
 306:lib/widget.c  ****     MENUNODE *thisMenu = (MENUNODE *) this;     
 307:lib/widget.c  ****     static uint16 noOfList;
 308:lib/widget.c  ****     switch(reflash)
 309:lib/widget.c  ****     {
 310:lib/widget.c  ****         case TRUE: // 화면이 바뀔때 실행
 311:lib/widget.c  ****             {
 312:lib/widget.c  ****                 noOfList = getNoOfChild(thisMenu);
 313:lib/widget.c  ****                 g_ListMenu.curPage = 0;
 314:lib/widget.c  ****                 SetDrawNodeListButtons(thisMenu, &g_ListMenu);
 315:lib/widget.c  ****                 UpdateDrawListButtons(&g_ListMenu,NO_SELECT);
 316:lib/widget.c  ****                 SetDrawBottomButtons("QUIT", NULL, BUTTON_STYLE_R_GREEN, BUTTON_STYLE_R_BLUE); 
 317:lib/widget.c  ****             }
 318:lib/widget.c  ****             break;  
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccS26oY7.s 			page 16


 319:lib/widget.c  ****         
 320:lib/widget.c  ****         case FALSE: // Cliking Check
 321:lib/widget.c  ****             {
 322:lib/widget.c  ****                 TOUCH tc = GetTouch();
 323:lib/widget.c  ****                 if(tc.isClick == FALSE) break;
 324:lib/widget.c  ****                 
 325:lib/widget.c  ****                 uint16 idx = getIndexOfClickedListMenu(&tc, &g_ListMenu);
 326:lib/widget.c  ****                 
 327:lib/widget.c  ****                 switch(idx)
 328:lib/widget.c  ****                 {
 329:lib/widget.c  ****                     case IDX_SCROLL_UP:   g_ListMenu.curPage--;
 330:lib/widget.c  ****                           UpdateDrawListButtons(&g_ListMenu,NO_SELECT);
 331:lib/widget.c  ****                         break;
 332:lib/widget.c  ****                     case IDX_SCROLL_DOWN: g_ListMenu.curPage++;
 333:lib/widget.c  ****                           UpdateDrawListButtons(&g_ListMenu,NO_SELECT);                   
 334:lib/widget.c  ****                         break;
 335:lib/widget.c  ****                     case NO_CLICK :
 336:lib/widget.c  ****                         {
 337:lib/widget.c  ****                             switch(getIndexOfClickedButton(&tc,g_btnBottom,2))
 338:lib/widget.c  ****                             {
 339:lib/widget.c  ****                                 case BOTTOM_LEFT:  return MENU_RETURN_PARENT;
 340:lib/widget.c  ****                             //  case BOTTOM_RIGHT: return 1;                            
 341:lib/widget.c  ****                             }
 342:lib/widget.c  ****                             break;
 343:lib/widget.c  ****                         }
 344:lib/widget.c  ****                     default: 
 345:lib/widget.c  ****                         if(idx < noOfList) return idx;
 346:lib/widget.c  ****                 }                
 347:lib/widget.c  ****             }
 348:lib/widget.c  ****             break;
 349:lib/widget.c  ****     }
 350:lib/widget.c  ****     return MENU_RETURN_THIS;    
 351:lib/widget.c  **** }
