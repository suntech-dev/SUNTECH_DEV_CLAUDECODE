  39:lib/jsmn.h    **** /**
  40:lib/jsmn.h    ****  * JSON type identifier. Basic types are:
  41:lib/jsmn.h    ****  * 	o Object
  42:lib/jsmn.h    ****  * 	o Array
  43:lib/jsmn.h    ****  * 	o String
  44:lib/jsmn.h    ****  * 	o Other primitive: number, boolean (true/false) or null
  45:lib/jsmn.h    ****  */
  46:lib/jsmn.h    **** typedef enum {
  47:lib/jsmn.h    ****   JSMN_UNDEFINED = 0,
  48:lib/jsmn.h    ****   JSMN_OBJECT = 1,
  49:lib/jsmn.h    ****   JSMN_ARRAY = 2,
  50:lib/jsmn.h    ****   JSMN_STRING = 3,
  51:lib/jsmn.h    ****   JSMN_PRIMITIVE = 4
  52:lib/jsmn.h    **** } jsmntype_t;
  53:lib/jsmn.h    **** 
  54:lib/jsmn.h    **** enum jsmnerr {
  55:lib/jsmn.h    ****   /* Not enough tokens were provided */
  56:lib/jsmn.h    ****   JSMN_ERROR_NOMEM = -1,
  57:lib/jsmn.h    ****   /* Invalid character inside JSON string */
  58:lib/jsmn.h    ****   JSMN_ERROR_INVAL = -2,
  59:lib/jsmn.h    ****   /* The string is not a full JSON packet, more bytes expected */
  60:lib/jsmn.h    ****   JSMN_ERROR_PART = -3
  61:lib/jsmn.h    **** };
  62:lib/jsmn.h    **** 
  63:lib/jsmn.h    **** /**
  64:lib/jsmn.h    ****  * JSON token description.
  65:lib/jsmn.h    ****  * type		type (object, array, string etc.)
  66:lib/jsmn.h    ****  * start	start position in JSON data string
  67:lib/jsmn.h    ****  * end		end position in JSON data string
  68:lib/jsmn.h    ****  */
