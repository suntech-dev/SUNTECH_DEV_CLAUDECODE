 333:lib/widget.c  ****     switch(reflash)
 334:lib/widget.c  ****     {
 335:lib/widget.c  ****         case TRUE: // 화면이 바뀔때 실행
 336:lib/widget.c  ****             {
 337:lib/widget.c  ****                 noOfList = getNoOfChild(thisMenu);
 338:lib/widget.c  ****                 g_ListMenu.curPage = 0;
