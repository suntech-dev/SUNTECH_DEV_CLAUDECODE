 343:lib/widget.c  ****             break;  
 344:lib/widget.c  ****         
 345:lib/widget.c  ****         case FALSE: // Cliking Check
 346:lib/widget.c  ****             {
 347:lib/widget.c  ****                 TOUCH tc = GetTouch();
 348:lib/widget.c  ****                 if(tc.isClick == FALSE) break;
 349:lib/widget.c  ****                 
 350:lib/widget.c  ****                 uint16 idx = getIndexOfClickedListMenu(&tc, &g_ListMenu);
 351:lib/widget.c  ****                 
 352:lib/widget.c  ****                 switch(idx)
 353:lib/widget.c  ****                 {
 354:lib/widget.c  ****                     case IDX_SCROLL_UP:   g_ListMenu.curPage--;
 355:lib/widget.c  ****                           UpdateDrawListButtons(&g_ListMenu,NO_SELECT);
 356:lib/widget.c  ****                         break;
 357:lib/widget.c  ****                     case IDX_SCROLL_DOWN: g_ListMenu.curPage++;
 358:lib/widget.c  ****                           UpdateDrawListButtons(&g_ListMenu,NO_SELECT);                   
 359:lib/widget.c  ****                         break;
 360:lib/widget.c  ****                     case NO_CLICK :
 361:lib/widget.c  ****                         {
 362:lib/widget.c  ****                             switch(getIndexOfClickedButton(&tc,g_btnBottom,2))
 363:lib/widget.c  ****                             {
 364:lib/widget.c  ****                                 case BOTTOM_LEFT:  return MENU_RETURN_PARENT;
 365:lib/widget.c  ****                             //  case BOTTOM_RIGHT: return 1;                            
 366:lib/widget.c  ****                             }
 367:lib/widget.c  ****                             break;
 368:lib/widget.c  ****                         }
 369:lib/widget.c  ****                     default: 
 370:lib/widget.c  ****                         if(idx < noOfList) return idx;
 371:lib/widget.c  ****                 }                
 372:lib/widget.c  ****             }
 373:lib/widget.c  ****             break;
 374:lib/widget.c  ****     }
 375:lib/widget.c  ****     return MENU_RETURN_THIS;    
 376:lib/widget.c  **** }
