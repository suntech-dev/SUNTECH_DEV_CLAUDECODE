 270:lib/widget.c  **** void UpdateDrawListButtons(LIST_MENU *menu, uint16 indexSelect)
 271:lib/widget.c  **** {
 272:lib/widget.c  ****     uint16 yPos;    
 273:lib/widget.c  ****         
 274:lib/widget.c  ****     for(int i=0; i < menu->noOfDisplayButton; i++)
 275:lib/widget.c  ****     {                        
 276:lib/widget.c  ****         int j = i+menu->curPage*menu->noOfDisplayButton;
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccgnak9m.s 			page 13


 277:lib/widget.c  ****         if(j >= menu->sizeOfList) break;
 278:lib/widget.c  ****         
 279:lib/widget.c  ****         BUTTON *btn = &menu->btns[i];
 280:lib/widget.c  ****         
 281:lib/widget.c  ****         if(indexSelect != NO_SELECT)
 282:lib/widget.c  ****         {
 283:lib/widget.c  ****             char buff[30];
 284:lib/widget.c  ****             sprintf(buff,"%c%s",(indexSelect==j) ? '>' : ' ',menu->listText[j]);
 285:lib/widget.c  ****             strcpy(btn->text,buff);              
 286:lib/widget.c  ****         } else {
 287:lib/widget.c  ****             SetButtonText(btn,menu->listText[j]);              
 288:lib/widget.c  ****         }
 289:lib/widget.c  **** 
 290:lib/widget.c  ****         DrawButton(btn);
 291:lib/widget.c  ****         yPos = btn->rect.bottom + 1;
 292:lib/widget.c  ****     }
 293:lib/widget.c  ****     
 294:lib/widget.c  ****     EraseBlankArea(yPos, isExistScroll(menu));
 295:lib/widget.c  **** }
