 315:lib/manageMenu.c **** /// doBrightness   ////////////////////////////////////////////////////////////////////////////////
 316:lib/manageMenu.c **** ///////////////////////////////////////////////////////////////////////////////////////////////////
 317:lib/manageMenu.c **** void DisplayDoBrigtness(char *title, UP_DOWN_ONE_MENU *menu);
 318:lib/manageMenu.c **** void DisplayDoBrigtnessSelectValue(UP_DOWN_ONE_MENU *menu, uint8 selectIncre, uint16 value);
 319:lib/manageMenu.c **** void DisplayDoBrigtnessValueChange(UP_DOWN_ONE_MENU *menu, uint16 value);
 320:lib/manageMenu.c **** 
 321:lib/manageMenu.c **** int doBrightness(void *this, uint8 reflash)
 322:lib/manageMenu.c **** {
 323:lib/manageMenu.c ****     MENUNODE *thisMenu = (MENUNODE *) this;
 324:lib/manageMenu.c ****     static UP_DOWN_ONE_MENU menu;   
 325:lib/manageMenu.c ****     
 326:lib/manageMenu.c ****     static uint16 selectIncre = 0;
 327:lib/manageMenu.c ****     static uint16 value = 50;
 328:lib/manageMenu.c **** 
 329:lib/manageMenu.c ****     switch(reflash)
 330:lib/manageMenu.c ****     {
 331:lib/manageMenu.c ****         case TRUE: // 화면이 바뀔때 실행
 332:lib/manageMenu.c ****             {                
 333:lib/manageMenu.c ****                 value = getMiscConfig()->uBrightness;
 334:lib/manageMenu.c ****                 
 335:lib/manageMenu.c ****                 DisplayDoBrigtness(thisMenu->nodeName,&menu);
 336:lib/manageMenu.c ****                 DisplayDoBrigtnessSelectValue(&menu, selectIncre, value);
 337:lib/manageMenu.c ****             }
 338:lib/manageMenu.c ****             break;  
 339:lib/manageMenu.c ****         
 340:lib/manageMenu.c ****         case FALSE: // Cliking Check
 341:lib/manageMenu.c ****             {
 342:lib/manageMenu.c **** 
 343:lib/manageMenu.c ****                 TOUCH tc = GetTouch();
 344:lib/manageMenu.c ****                 if(tc.isClick == FALSE) break;
 345:lib/manageMenu.c ****                 uint16 indexClick = getIndexOfClickedButton(&tc, menu.btn,8);
 346:lib/manageMenu.c ****                 switch(indexClick)
 347:lib/manageMenu.c ****                 {                  
 348:lib/manageMenu.c ****                     case 3: // for up
 349:lib/manageMenu.c ****                         if      (value+menu.inc[selectIncre] < 100)
 350:lib/manageMenu.c ****                         {
 351:lib/manageMenu.c ****                             value+=menu.inc[selectIncre];
 352:lib/manageMenu.c ****                             LED_Brightness(value);
 353:lib/manageMenu.c ****                             DisplayDoBrigtnessValueChange(&menu,value);
 354:lib/manageMenu.c ****                         }
 355:lib/manageMenu.c ****                         break;                       
 356:lib/manageMenu.c ****                     case 4: // for down
 357:lib/manageMenu.c ****                         if      (value-menu.inc[selectIncre] > 0)
 358:lib/manageMenu.c ****                         {
 359:lib/manageMenu.c ****                             value-=menu.inc[selectIncre];
 360:lib/manageMenu.c ****                             LED_Brightness(value);
 361:lib/manageMenu.c ****                             DisplayDoBrigtnessValueChange(&menu,value);
 362:lib/manageMenu.c ****                         }
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccnmqO0c.s 			page 11


 363:lib/manageMenu.c ****                         break;               
 364:lib/manageMenu.c ****                         break;                        
 365:lib/manageMenu.c ****                     case 5:
 366:lib/manageMenu.c ****                         selectIncre = 0;
 367:lib/manageMenu.c ****                         DisplayDoBrigtnessSelectValue(&menu,selectIncre, value);                   
 368:lib/manageMenu.c ****                         break;
 369:lib/manageMenu.c ****                     case 6:
 370:lib/manageMenu.c ****                         selectIncre = 1;
 371:lib/manageMenu.c ****                         DisplayDoBrigtnessSelectValue(&menu,selectIncre, value);
 372:lib/manageMenu.c ****                         break;
 373:lib/manageMenu.c ****                     case 7:
 374:lib/manageMenu.c ****                         selectIncre = 2;
 375:lib/manageMenu.c ****                         DisplayDoBrigtnessSelectValue(&menu,selectIncre, value);
 376:lib/manageMenu.c ****                         break;                        
 377:lib/manageMenu.c ****                     default:
 378:lib/manageMenu.c ****                         switch(getIndexOfClickedButton(&tc,g_btnBottom,2))
 379:lib/manageMenu.c ****                         {
 380:lib/manageMenu.c ****                             case BOTTOM_LEFT:
 381:lib/manageMenu.c ****                                 LED_Brightness(getMiscConfig()->uBrightness);
 382:lib/manageMenu.c ****                                 return MENU_RETURN_PARENT;
 383:lib/manageMenu.c ****                             case BOTTOM_RIGHT: 
 384:lib/manageMenu.c ****                             {
 385:lib/manageMenu.c ****                                 getMiscConfig()->uBrightness = value;
 386:lib/manageMenu.c ****                                 LED_Brightness(getMiscConfig()->uBrightness);      
 387:lib/manageMenu.c ****                                 ShowWaitMessage();
 388:lib/manageMenu.c ****                                 SaveExternalFlashConfig();
 389:lib/manageMenu.c ****                                 return MENU_RETURN_PARENT;                                
 390:lib/manageMenu.c ****                             }                            
 391:lib/manageMenu.c ****                         }
 392:lib/manageMenu.c ****                     break;
 393:lib/manageMenu.c ****                 }                                  
 394:lib/manageMenu.c ****             }
 395:lib/manageMenu.c ****             break;
 396:lib/manageMenu.c ****     }
 397:lib/manageMenu.c ****     return MENU_RETURN_THIS;    
 398:lib/manageMenu.c **** }
 399:lib/manageMenu.c **** 
 400:lib/manageMenu.c **** void DisplayDoBrigtness(char *title, UP_DOWN_ONE_MENU *menu)
 401:lib/manageMenu.c **** {
 402:lib/manageMenu.c ****     menu->inc[0] = 1;
 403:lib/manageMenu.c ****     menu->inc[1] = 10;
 404:lib/manageMenu.c ****     menu->inc[2] = 30;
 405:lib/manageMenu.c ****     
 406:lib/manageMenu.c ****     SetDrawUpDownOneMenu(menu, "Bright.", title);
 407:lib/manageMenu.c ****     
 408:lib/manageMenu.c ****     menu->btn[0].disable = TRUE; // for no click title
 409:lib/manageMenu.c ****     menu->btn[1].disable = TRUE; // for no click title
 410:lib/manageMenu.c ****     menu->btn[2].disable = TRUE; // for no click title
 411:lib/manageMenu.c ****     
 412:lib/manageMenu.c ****     SetDrawBottomButtons("QUIT", "SAVE", BUTTON_STYLE_R_GREEN, BUTTON_STYLE_R_BLUE);  
 413:lib/manageMenu.c **** }
 414:lib/manageMenu.c **** 
 415:lib/manageMenu.c **** void DisplayDoBrigtnessSelectValue(UP_DOWN_ONE_MENU *menu, uint8 selectIncre, uint16 value)
 416:lib/manageMenu.c **** {
 417:lib/manageMenu.c ****     menu->btn[5].foregroundColor = ((selectIncre==0) ? ORANGE : DARKGREY);  // 1 incre
 418:lib/manageMenu.c ****     menu->btn[6].foregroundColor = ((selectIncre==1) ? ORANGE : DARKGREY);  // 2 incre  
 419:lib/manageMenu.c ****     menu->btn[7].foregroundColor = ((selectIncre==2) ? ORANGE : DARKGREY);  // 3 incre  
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccnmqO0c.s 			page 12


 420:lib/manageMenu.c **** 
 421:lib/manageMenu.c ****     DrawButton(&menu->btn[5]);
 422:lib/manageMenu.c ****     DrawButton(&menu->btn[6]);
 423:lib/manageMenu.c ****     DrawButton(&menu->btn[7]);
 424:lib/manageMenu.c ****     
 425:lib/manageMenu.c ****     DisplayDoBrigtnessValueChange(menu,value);    
 426:lib/manageMenu.c **** }
 427:lib/manageMenu.c **** 
 428:lib/manageMenu.c **** void DisplayDoBrigtnessValueChange(UP_DOWN_ONE_MENU *menu, uint16 value)
 429:lib/manageMenu.c **** {
 430:lib/manageMenu.c ****     SetButtonText(&menu->btn[2],"%d",value);
 431:lib/manageMenu.c ****     DrawButton(&menu->btn[2]);
 432:lib/manageMenu.c **** }
