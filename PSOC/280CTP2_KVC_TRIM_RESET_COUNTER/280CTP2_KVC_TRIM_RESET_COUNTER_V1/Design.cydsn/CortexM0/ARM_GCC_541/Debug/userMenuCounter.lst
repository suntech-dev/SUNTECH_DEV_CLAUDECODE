 308:userMenuCounter.c ****                         break;
 309:userMenuCounter.c ****                     case SEWING_MACHINE:
 310:userMenuCounter.c ****                         value  = g_ptrMachineParameter->sewingTarget;
 311:userMenuCounter.c ****                         break;
 312:userMenuCounter.c ****                     break;
