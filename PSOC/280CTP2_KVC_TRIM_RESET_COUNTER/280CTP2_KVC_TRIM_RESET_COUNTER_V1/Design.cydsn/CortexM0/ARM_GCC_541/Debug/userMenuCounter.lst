 317:userMenuCounter.c ****             }
 318:userMenuCounter.c ****             break;  
 319:userMenuCounter.c ****         
 320:userMenuCounter.c ****         case FALSE: // Cliking Check
 321:userMenuCounter.c ****             {
 322:userMenuCounter.c **** 
 323:userMenuCounter.c ****                 TOUCH tc = GetTouch();
 324:userMenuCounter.c ****                 if(tc.isClick == FALSE) break;
 325:userMenuCounter.c ****                 uint16 indexClick = getIndexOfClickedButton(&tc, menu.btn,8);
 326:userMenuCounter.c ****                 switch(indexClick)
 327:userMenuCounter.c ****                 {                  
 328:userMenuCounter.c ****                     case 3: // for up
 329:userMenuCounter.c ****                         if      (value+menu.inc[selectIncre] < 100)
 330:userMenuCounter.c ****                         {
 331:userMenuCounter.c ****                             value+=menu.inc[selectIncre];
 332:userMenuCounter.c ****                             DisplayDoTargetInfoMenuValueChange(&menu,value);
 333:userMenuCounter.c ****                         }
 334:userMenuCounter.c ****                         break;                       
 335:userMenuCounter.c ****                     case 4: // for down
 336:userMenuCounter.c ****                         if      (value-menu.inc[selectIncre] > 0)
 337:userMenuCounter.c ****                         {
 338:userMenuCounter.c ****                             value-=menu.inc[selectIncre];
 339:userMenuCounter.c ****                             DisplayDoTargetInfoMenuValueChange(&menu,value);
 340:userMenuCounter.c ****                         }
 341:userMenuCounter.c ****                         break;               
 342:userMenuCounter.c ****                         break;                        
 343:userMenuCounter.c ****                     case 5:
 344:userMenuCounter.c ****                         selectIncre = 0;
 345:userMenuCounter.c ****                         DisplayDoTargetInfoMenuSelectValue(&menu,selectIncre, value);
 346:userMenuCounter.c ****                         break;
 347:userMenuCounter.c ****                     case 6:
 348:userMenuCounter.c ****                         selectIncre = 1;
 349:userMenuCounter.c ****                         DisplayDoTargetInfoMenuSelectValue(&menu,selectIncre, value);
 350:userMenuCounter.c ****                         break;
 351:userMenuCounter.c ****                     case 7:
 352:userMenuCounter.c ****                         selectIncre = 2;
 353:userMenuCounter.c ****                         DisplayDoTargetInfoMenuSelectValue(&menu,selectIncre, value);
 354:userMenuCounter.c ****                         break;                        
 355:userMenuCounter.c ****                     default:
 356:userMenuCounter.c ****                         switch(getIndexOfClickedButton(&tc,g_btnBottom,2))
 357:userMenuCounter.c ****                         {
 358:userMenuCounter.c ****                             case BOTTOM_LEFT:  return MENU_RETURN_PARENT;
 359:userMenuCounter.c ****                    
 360:userMenuCounter.c ****                             case BOTTOM_RIGHT: 
 361:userMenuCounter.c ****                             {
 362:userMenuCounter.c ****                                 g_ptrMachineParameter->setTrimCount = value;
 363:userMenuCounter.c **** 
 364:userMenuCounter.c ****                                 ShowWaitMessage();
 365:userMenuCounter.c ****                                 
 366:userMenuCounter.c ****                                 if(g_ptrMachineParameter->setTrimCount < g_ptrCount->count)
 367:userMenuCounter.c ****                                 {
 368:userMenuCounter.c ****                                     g_ptrCount->count = g_ptrMachineParameter->setTrimCount;
 369:userMenuCounter.c ****                                     SaveInternalFlash();
 370:userMenuCounter.c ****                                 }
 371:userMenuCounter.c ****                                        
