 299:userMenuCounter.c **** 
 300:userMenuCounter.c ****     switch(reflash)
 301:userMenuCounter.c ****     {
 302:userMenuCounter.c ****         case TRUE: // 화면이 바뀔때 실행
 303:userMenuCounter.c ****             {/*
 304:userMenuCounter.c ****                 switch(g_ptrMachineParameter->machineType)
 305:userMenuCounter.c ****                 {
 306:userMenuCounter.c ****                     case PATTERN_MACHINE: 
