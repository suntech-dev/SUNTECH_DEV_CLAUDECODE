  52:lib\yarosla-nxjson/nxjson.c **** static nx_json* create_json(nx_json_type type, const char* key, nx_json* parent) {
  53:lib\yarosla-nxjson/nxjson.c ****   nx_json* js=NX_JSON_CALLOC();
  54:lib\yarosla-nxjson/nxjson.c ****   assert(js);
  55:lib\yarosla-nxjson/nxjson.c ****   js->type=type;
  56:lib\yarosla-nxjson/nxjson.c ****   js->key=key;
  57:lib\yarosla-nxjson/nxjson.c ****   if (!parent->last_child) {
  58:lib\yarosla-nxjson/nxjson.c ****     parent->child=parent->last_child=js;
  59:lib\yarosla-nxjson/nxjson.c ****   }
  60:lib\yarosla-nxjson/nxjson.c ****   else {
  61:lib\yarosla-nxjson/nxjson.c ****     parent->last_child->next=js;
  62:lib\yarosla-nxjson/nxjson.c ****     parent->last_child=js;
  63:lib\yarosla-nxjson/nxjson.c ****   }
  64:lib\yarosla-nxjson/nxjson.c ****   parent->length++;
  65:lib\yarosla-nxjson/nxjson.c ****   return js;
  66:lib\yarosla-nxjson/nxjson.c **** }
  67:lib\yarosla-nxjson/nxjson.c **** 
  68:lib\yarosla-nxjson/nxjson.c **** void nx_json_free(const nx_json* js) {
  69:lib\yarosla-nxjson/nxjson.c ****   nx_json* p=js->child;
  70:lib\yarosla-nxjson/nxjson.c ****   nx_json* p1;
  71:lib\yarosla-nxjson/nxjson.c ****   while (p) {
  72:lib\yarosla-nxjson/nxjson.c ****     p1=p->next;
  73:lib\yarosla-nxjson/nxjson.c ****     nx_json_free(p);
  74:lib\yarosla-nxjson/nxjson.c ****     p=p1;
  75:lib\yarosla-nxjson/nxjson.c ****   }
  76:lib\yarosla-nxjson/nxjson.c ****   NX_JSON_FREE(js);
  77:lib\yarosla-nxjson/nxjson.c **** }
