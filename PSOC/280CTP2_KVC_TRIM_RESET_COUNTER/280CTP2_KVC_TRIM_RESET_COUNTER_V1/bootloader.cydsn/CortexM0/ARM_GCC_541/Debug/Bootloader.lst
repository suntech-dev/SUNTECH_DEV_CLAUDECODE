 577:Generated_Source\PSoC4/Bootloader.c **** static cystatus Bootloader_CopyRow(uint16 srcRowNum, uint16 dstRowNum) \
 578:Generated_Source\PSoC4/Bootloader.c ****                  CYSMALL 
 579:Generated_Source\PSoC4/Bootloader.c **** {
 580:Generated_Source\PSoC4/Bootloader.c ****     /*Buffer for row copy procedure*/
