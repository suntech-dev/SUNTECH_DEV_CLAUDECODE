 686:Generated_Source\PSoC4/Bootloader.c ****     }
 687:Generated_Source\PSoC4/Bootloader.c ****         
 688:Generated_Source\PSoC4/Bootloader.c ****     /*************************************************************************
 689:Generated_Source\PSoC4/Bootloader.c ****     * Copying the number of rows from source (temporary location) to destination.
 690:Generated_Source\PSoC4/Bootloader.c ****     * If the operation is unsuccessful, there will be a few more attempts to
 691:Generated_Source\PSoC4/Bootloader.c ****     * perform the copying operation (a number is defined by Bootloader_MAX_ATTEMPTS)
 692:Generated_Source\PSoC4/Bootloader.c ****     ***************************************************************************/
 693:Generated_Source\PSoC4/Bootloader.c ****     for(idx = 0; idx < numberOfRows; idx++)
 694:Generated_Source\PSoC4/Bootloader.c ****     {
 695:Generated_Source\PSoC4/Bootloader.c ****         copierAttempts = Bootloader_MAX_ATTEMPTS;
 696:Generated_Source\PSoC4/Bootloader.c ****         
 697:Generated_Source\PSoC4/Bootloader.c ****         do 
