  29:lib/USB.c     **** void usbLoop()
  30:lib/USB.c     **** {
  31:lib/USB.c     ****     /* Host can send double SET_INTERFACE request. */
  32:lib/USB.c     ****     if (0u != USBUART_IsConfigurationChanged())
  33:lib/USB.c     ****     {
  34:lib/USB.c     ****         /* Initialize IN endpoints when device is configured. */
  35:lib/USB.c     ****         if (0u != USBUART_GetConfiguration())
  36:lib/USB.c     ****         {
  37:lib/USB.c     ****             /* Enumeration is done, enable OUT endpoint to receive data
  38:lib/USB.c     ****              * from host. */
  39:lib/USB.c     ****             USBUART_CDC_Init();
  40:lib/USB.c     ****             s_cdc_init_done = 1u;
  41:lib/USB.c     ****         }
  42:lib/USB.c     ****         else
  43:lib/USB.c     ****         {
  44:lib/USB.c     ****             /* USB 분리 — 재연결 시 스타트업 메시지 다시 표시 */
  45:lib/USB.c     ****             s_cdc_init_done = 0u;
  46:lib/USB.c     ****             s_startup_sent  = 0u;
  47:lib/USB.c     ****         }
  48:lib/USB.c     ****     }
  49:lib/USB.c     **** 
  50:lib/USB.c     ****     /* Fallback: 보드가 USB 연결 상태에서 부팅된 경우 IsConfigurationChanged()가
  51:lib/USB.c     ****      * 발생하지 않아 CDC_Init()이 누락될 수 있음 — GetConfiguration()이 이미
  52:lib/USB.c     ****      * non-zero 이면 여기서 한 번만 초기화. */
  53:lib/USB.c     ****     if (0u == s_cdc_init_done && 0u != USBUART_GetConfiguration())
  54:lib/USB.c     ****     {
  55:lib/USB.c     ****         USBUART_CDC_Init();
  56:lib/USB.c     ****         s_cdc_init_done = 1u;
  57:lib/USB.c     ****     }
  58:lib/USB.c     **** 
  59:lib/USB.c     ****     /* Service USB CDC when device is configured. */
  60:lib/USB.c     ****     if (0u != USBUART_GetConfiguration())
