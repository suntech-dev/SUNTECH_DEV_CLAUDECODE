 123:uartJson.c    **** /* ================================================================
 124:uartJson.c    ****  * uartJsonLoop — 메인 루프에서 호출
 125:uartJson.c    ****  *
 126:uartJson.c    ****  * '\n'/'\r' 수신       → WHITE 확정 (정상 라인)
 127:uartJson.c    ****  * 버퍼 오버플로우      → WHITE 확정 (1023자 초과 시 강제 커밋)
 128:uartJson.c    ****  * 타임아웃 flush       → WHITE 확정 (UART_IDLE_FLUSH_COUNT 루프 무수신)
 129:uartJson.c    ****  * → 모든 경우에 WHITE 로 표시 ('\n' 없는 데이터도 LCD 에 표시됨)
 130:uartJson.c    ****  * ================================================================ */
 131:uartJson.c    **** uint8 uartJsonLoop(void)
 132:uartJson.c    **** {
 280              		.loc 1 132 0
 281              		.cfi_startproc
