 213:lib/widget.c  ****             if(textIdx >= menu->sizeOfList) break;
 214:lib/widget.c  ****             
 215:lib/widget.c  ****             strcpy(btn->text,menu->listText[textIdx]);        
 216:lib/widget.c  ****             yPos += g_DEFAULT_BUTTON_HEIGHT;
