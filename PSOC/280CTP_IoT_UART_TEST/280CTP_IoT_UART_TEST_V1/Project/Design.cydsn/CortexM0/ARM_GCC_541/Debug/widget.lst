 200:lib/widget.c  ****         {  
 201:lib/widget.c  ****             strcpy(menu->listText[i],getNthChild(parent,i)->nodeName);              
 202:lib/widget.c  ****         }
 203:lib/widget.c  ****         
 204:lib/widget.c  ****         for(int i=0; i < menu->noOfDisplayButton; i++)
 205:lib/widget.c  ****         {                        
