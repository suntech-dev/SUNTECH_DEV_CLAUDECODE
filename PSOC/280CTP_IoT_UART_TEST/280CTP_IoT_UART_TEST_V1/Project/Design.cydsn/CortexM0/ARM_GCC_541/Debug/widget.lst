 226:lib/widget.c  **** void UpdateDrawListButtons(LIST_MENU *menu, uint16 indexSelect)
 227:lib/widget.c  **** {
 228:lib/widget.c  ****     RECT bodyRect = GetBodyArea();
 229:lib/widget.c  ****     uint16 yPos = bodyRect.top;
 230:lib/widget.c  ****         
 231:lib/widget.c  ****     for(int i=0; i < menu->noOfDisplayButton; i++)
 232:lib/widget.c  ****     {                        
 233:lib/widget.c  ****         int j = i+menu->curPage*menu->noOfDisplayButton;
 234:lib/widget.c  ****         if(j >= menu->sizeOfList) break;
 235:lib/widget.c  **** 
 236:lib/widget.c  ****         BUTTON *btn = &menu->btns[i];
 237:lib/widget.c  **** 
 238:lib/widget.c  ****         if(indexSelect != NO_SELECT)
 239:lib/widget.c  ****         {
 240:lib/widget.c  ****             char buff[MAX_BUTTON_TEXT_SIZE];
 241:lib/widget.c  ****             sprintf(buff,"%c%s",(indexSelect==j) ? '>' : ' ',menu->listText[j]);
 242:lib/widget.c  ****             strcpy(btn->text,buff);
 243:lib/widget.c  ****         } else {
 244:lib/widget.c  ****            strcpy(btn->text,menu->listText[j]); 
 245:lib/widget.c  ****         }
 246:lib/widget.c  ****         
 247:lib/widget.c  ****         DrawButton(btn);
 248:lib/widget.c  ****         yPos = btn->rect.bottom + 1;
 249:lib/widget.c  ****     }
 250:lib/widget.c  ****     
 251:lib/widget.c  ****     EraseBlankArea(yPos, isExistScroll(menu));
 252:lib/widget.c  **** }
