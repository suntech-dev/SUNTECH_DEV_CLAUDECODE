 701:Generated_Source\PSoC4/Bootloader.c ****             
 702:Generated_Source\PSoC4/Bootloader.c ****             /* Decrementing counter of attempts to repeat copying operation */
 703:Generated_Source\PSoC4/Bootloader.c ****             copierAttempts--;       
 704:Generated_Source\PSoC4/Bootloader.c ****         } while ((CYRET_SUCCESS != copyStatus) && (0u != copierAttempts));
 705:Generated_Source\PSoC4/Bootloader.c **** 
 706:Generated_Source\PSoC4/Bootloader.c ****         
 707:Generated_Source\PSoC4/Bootloader.c ****         /*************************************************************************
 708:Generated_Source\PSoC4/Bootloader.c ****         * If a problem occurs, when a row can't be copied, "CopyFlag" should be
 709:Generated_Source\PSoC4/Bootloader.c ****         * cleared to prevent the recurrent copying that might follow the software reset.        
 710:Generated_Source\PSoC4/Bootloader.c ****         ***************************************************************************/
