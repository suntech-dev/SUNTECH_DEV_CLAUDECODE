 597:Generated_Source\PSoC4/Bootloader.c **** /*******************************************************************************
 598:Generated_Source\PSoC4/Bootloader.c **** * Function Name: Bootloader_Copier
 599:Generated_Source\PSoC4/Bootloader.c **** ****************************************************************************//**
 600:Generated_Source\PSoC4/Bootloader.c **** *  \internal
 601:Generated_Source\PSoC4/Bootloader.c **** *  
 602:Generated_Source\PSoC4/Bootloader.c **** *  \brief
 603:Generated_Source\PSoC4/Bootloader.c **** *    This option is specific for Launcher-Combination architecture only and to 
 604:Generated_Source\PSoC4/Bootloader.c **** *    the case when there is a large communication component like BLE. To save 
 605:Generated_Source\PSoC4/Bootloader.c **** *    flash space for the user application, such a large communication component 
 606:Generated_Source\PSoC4/Bootloader.c **** *    is present only in the first application (Stack application) and is "shared" 
 607:Generated_Source\PSoC4/Bootloader.c **** *    with the second application (the user's application actually) by "Code 
 608:Generated_Source\PSoC4/Bootloader.c **** *    sharing feature" (See code sharing and BLE Upgradable Stack example project). 
 609:Generated_Source\PSoC4/Bootloader.c **** *
 610:Generated_Source\PSoC4/Bootloader.c **** * \n If this option is enabled and the "need-to-copy" flag is set in the second 
 611:Generated_Source\PSoC4/Bootloader.c **** *    application's metadata, Copier performs copying of a previously saved Stack 
ARM GAS  C:\Users\dev\AppData\Local\Temp\ccHuCwCQ.s 			page 13


 612:Generated_Source\PSoC4/Bootloader.c **** *    application image from a "temporary location" to the app#1 flash 
 613:Generated_Source\PSoC4/Bootloader.c **** *    space (over the current app#1).
 614:Generated_Source\PSoC4/Bootloader.c **** *   
 615:Generated_Source\PSoC4/Bootloader.c **** * \n Before performing the copying operation the new Stack application image 
 616:Generated_Source\PSoC4/Bootloader.c **** *    should be received and stored at the temporary location by the current 
 617:Generated_Source\PSoC4/Bootloader.c **** *    Stack application. The "need-to-copy" flag should be set in app#2 metadata 
 618:Generated_Source\PSoC4/Bootloader.c **** *    indicating that copying operation is required.
 619:Generated_Source\PSoC4/Bootloader.c **** *
 620:Generated_Source\PSoC4/Bootloader.c **** * \n The temporary location is half of the flash space that left after Launcher 
 621:Generated_Source\PSoC4/Bootloader.c **** *    and 2 metadata rows. This implies that Stack application should fit in 
 622:Generated_Source\PSoC4/Bootloader.c **** *    that half of the flash space. 
 623:Generated_Source\PSoC4/Bootloader.c **** *
 624:Generated_Source\PSoC4/Bootloader.c **** * \n The destination for the copy operation is obtained as the first row after 
 625:Generated_Source\PSoC4/Bootloader.c **** *    Launcher (from app#1 metadata). 
 626:Generated_Source\PSoC4/Bootloader.c **** *
 627:Generated_Source\PSoC4/Bootloader.c **** * \n The source of copy operation is the first row of temporary location that 
 628:Generated_Source\PSoC4/Bootloader.c **** *    is calculated by the following formula: 
 629:Generated_Source\PSoC4/Bootloader.c **** * \n     srcRow = (((CY_FLASH_NUMBER_ROWS - dstRow - metaRows) / 2) + dstRow);
 630:Generated_Source\PSoC4/Bootloader.c **** * \n     where:
 631:Generated_Source\PSoC4/Bootloader.c **** *          - dstRow - the destination's first row (mentioned above);
 632:Generated_Source\PSoC4/Bootloader.c **** *          - CY_FLASH_NUMBER_ROWS - number of all flash rows; 
 633:Generated_Source\PSoC4/Bootloader.c **** *          - metaRows - 2 metadata rows;   
 634:Generated_Source\PSoC4/Bootloader.c **** *
 635:Generated_Source\PSoC4/Bootloader.c **** * \n Copying itself means row-by-row copying of the stored application's image.
 636:Generated_Source\PSoC4/Bootloader.c **** *    If it fails to copy some row, there is a defined number of attempts 
 637:Generated_Source\PSoC4/Bootloader.c **** *    (Bootloader_MAX_ATTEMPTS) to try again. In case of no success, 
 638:Generated_Source\PSoC4/Bootloader.c **** *    a user callback function Launcher_CopierCallback() is called. 
 639:Generated_Source\PSoC4/Bootloader.c **** *    If it is not defined, then the device is going to be halted.
 640:Generated_Source\PSoC4/Bootloader.c **** * 
 641:Generated_Source\PSoC4/Bootloader.c **** * \n After performing the application image copying, in case of success 
 642:Generated_Source\PSoC4/Bootloader.c **** *    the app#2 metadata is copied in the stead of app#1 metadata and then
 643:Generated_Source\PSoC4/Bootloader.c **** *    app#2 metadata is cleared.
 644:Generated_Source\PSoC4/Bootloader.c **** *
 645:Generated_Source\PSoC4/Bootloader.c **** * \n A "need-to-copy" flag is cleared just after performing the app#1 image
 646:Generated_Source\PSoC4/Bootloader.c **** *    copying from the temporary location to avoid another consecutive 
 647:Generated_Source\PSoC4/Bootloader.c **** *    copying operation.
 648:Generated_Source\PSoC4/Bootloader.c **** *   
 649:Generated_Source\PSoC4/Bootloader.c **** * \endinternal 
 650:Generated_Source\PSoC4/Bootloader.c **** *******************************************************************************/
 651:Generated_Source\PSoC4/Bootloader.c **** static void Bootloader_Copier(void) CYSMALL \
 652:Generated_Source\PSoC4/Bootloader.c ****            
 653:Generated_Source\PSoC4/Bootloader.c **** {
 654:Generated_Source\PSoC4/Bootloader.c ****     uint16 idx = 0u;
 655:Generated_Source\PSoC4/Bootloader.c **** 
 656:Generated_Source\PSoC4/Bootloader.c ****     /* Number of attempts to perform copying again */
 657:Generated_Source\PSoC4/Bootloader.c ****     uint8 copierAttempts;
 658:Generated_Source\PSoC4/Bootloader.c ****     
 659:Generated_Source\PSoC4/Bootloader.c ****     /* "need-to-copy" flag from second application metadata */
 660:Generated_Source\PSoC4/Bootloader.c ****     uint8 copyFlag = Bootloader_GetMetadata(Bootloader_GET_BTLDB_COPY_FLAG, Bootloader_MD_BTLDB_ACT
 661:Generated_Source\PSoC4/Bootloader.c **** 
 662:Generated_Source\PSoC4/Bootloader.c ****     /* Buffer to temporary hold metadata before flashing */
 663:Generated_Source\PSoC4/Bootloader.c ****     uint8 metaBuf[CYDEV_FLS_ROW_SIZE];
 664:Generated_Source\PSoC4/Bootloader.c **** 
 665:Generated_Source\PSoC4/Bootloader.c ****     /* Launcher's last row number */
 666:Generated_Source\PSoC4/Bootloader.c ****     uint16 launcherLastRow = Bootloader_GetMetadata(Bootloader_GET_BTLDR_LAST_ROW, Bootloader_MD_BT
 667:Generated_Source\PSoC4/Bootloader.c **** 
 668:Generated_Source\PSoC4/Bootloader.c ****     /* Calculating destination's start row number (first row of app#1) */
ARM GAS  C:\Users\dev\AppData\Local\Temp\ccHuCwCQ.s 			page 14


 669:Generated_Source\PSoC4/Bootloader.c ****     uint16 dstRow = launcherLastRow + 1u;
 670:Generated_Source\PSoC4/Bootloader.c ****     
 671:Generated_Source\PSoC4/Bootloader.c ****     /* Calculating the source's/temporary location's start row number */
 672:Generated_Source\PSoC4/Bootloader.c ****     uint16 srcRow = ((((CY_FLASH_NUMBER_ROWS - dstRow - 2u) + 1u) >> 1u) + dstRow); 
 673:Generated_Source\PSoC4/Bootloader.c ****     
