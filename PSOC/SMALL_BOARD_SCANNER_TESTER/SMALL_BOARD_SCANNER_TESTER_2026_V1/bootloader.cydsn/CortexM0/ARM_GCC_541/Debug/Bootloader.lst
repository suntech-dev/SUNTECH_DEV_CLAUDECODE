 676:Generated_Source\PSoC4/Bootloader.c **** 
 677:Generated_Source\PSoC4/Bootloader.c ****     /* Copy operation status initialization */
 678:Generated_Source\PSoC4/Bootloader.c ****     cystatus copyStatus = CYRET_SUCCESS;
 679:Generated_Source\PSoC4/Bootloader.c ****     
 680:Generated_Source\PSoC4/Bootloader.c ****     /* Calculating number of rows for copying */
 681:Generated_Source\PSoC4/Bootloader.c ****     uint16 numberOfRows = srcLength / CYDEV_FLS_ROW_SIZE;
