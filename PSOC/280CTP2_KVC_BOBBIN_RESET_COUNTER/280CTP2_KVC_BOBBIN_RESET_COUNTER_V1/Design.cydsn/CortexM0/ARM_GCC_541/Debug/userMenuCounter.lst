 339:userMenuCounter.c ****                 DisplayDoTargetInfoMenu(&menu);
 340:userMenuCounter.c ****                 DisplayDoTargetInfoMenuSelectValue(&menu, selectIncre, value);
 341:userMenuCounter.c ****             }
 342:userMenuCounter.c ****             break;  
 343:userMenuCounter.c ****         
 344:userMenuCounter.c ****         case FALSE: // Cliking Check
 345:userMenuCounter.c ****             {
 346:userMenuCounter.c **** 
 347:userMenuCounter.c ****                 TOUCH tc = GetTouch();
 348:userMenuCounter.c ****                 if(tc.isClick == FALSE) break;
 349:userMenuCounter.c ****                 uint16 indexClick = getIndexOfClickedButton(&tc, menu.btn,8);
 350:userMenuCounter.c ****                 switch(indexClick)
 351:userMenuCounter.c ****                 {                  
 352:userMenuCounter.c ****                     case 3: // for up
 353:userMenuCounter.c ****                         if      (value+menu.inc[selectIncre] < 10000) //<--- 9999
 354:userMenuCounter.c ****                         {
 355:userMenuCounter.c ****                             value+=menu.inc[selectIncre];
 356:userMenuCounter.c ****                             DisplayDoTargetInfoMenuValueChange(&menu,value);
 357:userMenuCounter.c ****                         }
 358:userMenuCounter.c ****                         break;                       
 359:userMenuCounter.c ****                     case 4: // for down
