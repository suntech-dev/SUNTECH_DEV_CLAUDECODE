 363:userMenuCounter.c ****                             DisplayDoTargetInfoMenuValueChange(&menu,value);
 364:userMenuCounter.c ****                         }
 365:userMenuCounter.c ****                         break;               
 366:userMenuCounter.c ****                         break;                        
 367:userMenuCounter.c ****                     case 5:
 368:userMenuCounter.c ****                         selectIncre = 0;
 369:userMenuCounter.c ****                         DisplayDoTargetInfoMenuSelectValue(&menu,selectIncre, value);
 370:userMenuCounter.c ****                         break;
 371:userMenuCounter.c ****                     case 6:
 372:userMenuCounter.c ****                         selectIncre = 1;
 373:userMenuCounter.c ****                         DisplayDoTargetInfoMenuSelectValue(&menu,selectIncre, value);
 374:userMenuCounter.c ****                         break;
 375:userMenuCounter.c ****                     case 7:
 376:userMenuCounter.c ****                         selectIncre = 2;
 377:userMenuCounter.c ****                         DisplayDoTargetInfoMenuSelectValue(&menu,selectIncre, value);
 378:userMenuCounter.c ****                         break;                        
 379:userMenuCounter.c ****                     default:
 380:userMenuCounter.c ****                         switch(getIndexOfClickedButton(&tc,g_btnBottom,2))
 381:userMenuCounter.c ****                         {
