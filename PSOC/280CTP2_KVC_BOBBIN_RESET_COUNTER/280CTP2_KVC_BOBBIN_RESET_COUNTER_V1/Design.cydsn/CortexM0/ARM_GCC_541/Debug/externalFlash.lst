  60:lib/externalFlash.c **** // external flash에서 데이터를 호출한다
  61:lib/externalFlash.c **** uint8 LoadExternalFlashConfig()
  62:lib/externalFlash.c **** {
  63:lib/externalFlash.c ****     uint8_t *p = (uint8 *) & g_externalFlash;
  64:lib/externalFlash.c ****     
  65:lib/externalFlash.c ****     W25qxx_ReadBytes(p, g_uAddressForConfig,sizeof(EXTERNAL_CONFIG));
  66:lib/externalFlash.c ****     uint16 crc = externalFlashCRC();
  67:lib/externalFlash.c ****     
  68:lib/externalFlash.c ****     if(g_externalFlash.CRC != externalFlashCRC())  return FALSE;
