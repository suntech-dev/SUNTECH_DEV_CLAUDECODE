 332:lib/widget.c  **** int doListMenu(void *this, uint8 reflash) ///////////////////////////////////////////////////////
 333:lib/widget.c  **** /////////////////////////////////////////////////////////////////////////////////////////////////
 334:lib/widget.c  **** {    
 335:lib/widget.c  ****     MENUNODE *thisMenu = (MENUNODE *) this;     
 336:lib/widget.c  ****     static uint16 noOfList;
 337:lib/widget.c  ****     switch(reflash)
 338:lib/widget.c  ****     {
 339:lib/widget.c  ****         case TRUE: // 화면이 바뀔때 실행
 340:lib/widget.c  ****             {
 341:lib/widget.c  ****                 noOfList = getNoOfChild(thisMenu);
 342:lib/widget.c  ****                 g_ListMenu.curPage = 0;
 343:lib/widget.c  ****                 SetDrawNodeListButtons(thisMenu, &g_ListMenu);
 344:lib/widget.c  ****                 UpdateDrawListButtons(&g_ListMenu,NO_SELECT);
 345:lib/widget.c  ****                 SetDrawBottomButtons("QUIT", NULL, BUTTON_STYLE_R_GREEN, BUTTON_STYLE_R_BLUE); 
 346:lib/widget.c  ****             }
 347:lib/widget.c  ****             break;  
 348:lib/widget.c  ****         
 349:lib/widget.c  ****         case FALSE: // Cliking Check
 350:lib/widget.c  ****             {
 351:lib/widget.c  ****                 TOUCH tc = GetTouch();
 352:lib/widget.c  ****                 if(tc.isClick == FALSE) break;
 353:lib/widget.c  ****                 
 354:lib/widget.c  ****                 uint16 idx = getIndexOfClickedListMenu(&tc, &g_ListMenu);
 355:lib/widget.c  ****                 
 356:lib/widget.c  ****                 switch(idx)
 357:lib/widget.c  ****                 {
 358:lib/widget.c  ****                     case IDX_SCROLL_UP:   g_ListMenu.curPage--;
 359:lib/widget.c  ****                           UpdateDrawListButtons(&g_ListMenu,NO_SELECT);
 360:lib/widget.c  ****                         break;
 361:lib/widget.c  ****                     case IDX_SCROLL_DOWN: g_ListMenu.curPage++;
 362:lib/widget.c  ****                           UpdateDrawListButtons(&g_ListMenu,NO_SELECT);                   
 363:lib/widget.c  ****                         break;
 364:lib/widget.c  ****                     case NO_CLICK :
 365:lib/widget.c  ****                         {
 366:lib/widget.c  ****                             switch(getIndexOfClickedButton(&tc,g_btnBottom,2))
 367:lib/widget.c  ****                             {
 368:lib/widget.c  ****                                 case BOTTOM_LEFT:  return MENU_RETURN_PARENT;
 369:lib/widget.c  ****                             //  case BOTTOM_RIGHT: return 1;                            
 370:lib/widget.c  ****                             }
 371:lib/widget.c  ****                             break;
 372:lib/widget.c  ****                         }
 373:lib/widget.c  ****                     default: 
 374:lib/widget.c  ****                         if(idx < noOfList) return idx;
 375:lib/widget.c  ****                 }                
 376:lib/widget.c  ****             }
 377:lib/widget.c  ****             break;
 378:lib/widget.c  ****     }
 379:lib/widget.c  ****     return MENU_RETURN_THIS;    
 380:lib/widget.c  **** }
