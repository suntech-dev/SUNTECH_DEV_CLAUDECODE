 274:lib/widget.c  **** void UpdateDrawListButtons(LIST_MENU *menu, uint16 indexSelect)
 275:lib/widget.c  **** {
 276:lib/widget.c  ****     uint16 yPos;    
 277:lib/widget.c  ****         
 278:lib/widget.c  ****     for(int i=0; i < menu->noOfDisplayButton; i++)
 279:lib/widget.c  ****     {                        
 280:lib/widget.c  ****         int j = i+menu->curPage*menu->noOfDisplayButton;
 281:lib/widget.c  ****         if(j >= menu->sizeOfList) break;
 282:lib/widget.c  ****         
 283:lib/widget.c  ****         BUTTON *btn = &menu->btns[i];
 284:lib/widget.c  ****         
 285:lib/widget.c  ****         if(indexSelect != NO_SELECT)
 286:lib/widget.c  ****         {
 287:lib/widget.c  ****             char buff[30];
 288:lib/widget.c  ****             sprintf(buff,"%c%s",(indexSelect==j) ? '>' : ' ',menu->listText[j]);
 289:lib/widget.c  ****             strcpy(btn->text,buff);              
 290:lib/widget.c  ****         } else {
 291:lib/widget.c  ****             SetButtonText(btn,menu->listText[j]);              
 292:lib/widget.c  ****         }
 293:lib/widget.c  **** 
 294:lib/widget.c  ****         DrawButton(btn);
 295:lib/widget.c  ****         yPos = btn->rect.bottom + 1;
 296:lib/widget.c  ****     }
 297:lib/widget.c  ****     
 298:lib/widget.c  ****     EraseBlankArea(yPos, isExistScroll(menu));
 299:lib/widget.c  **** }
