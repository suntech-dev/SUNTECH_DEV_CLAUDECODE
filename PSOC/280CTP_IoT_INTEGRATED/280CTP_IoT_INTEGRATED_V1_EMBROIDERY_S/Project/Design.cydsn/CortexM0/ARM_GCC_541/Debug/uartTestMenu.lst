  85:uartTestMenu.c **** /* ================================================================
  86:uartTestMenu.c ****  * uartTestAddLine — uartJson.c 파싱 성공 시 미러 호출
  87:uartTestMenu.c ****  * ================================================================ */
  88:uartTestMenu.c **** void uartTestAddLine(const char *line)
  89:uartTestMenu.c **** {
  90:uartTestMenu.c ****     uint8 writeIdx;
  91:uartTestMenu.c **** 
  92:uartTestMenu.c ****     if (g_recCount < UART_VIEW_MAX_REC)
  93:uartTestMenu.c ****     {
  94:uartTestMenu.c ****         writeIdx = (g_recHead + g_recCount) % UART_VIEW_MAX_REC;
  95:uartTestMenu.c ****         g_recCount++;
  96:uartTestMenu.c ****     }
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccyutung.s 			page 6


  97:uartTestMenu.c ****     else
  98:uartTestMenu.c ****     {
  99:uartTestMenu.c ****         writeIdx  = g_recHead;
 100:uartTestMenu.c ****         g_recHead = (g_recHead + 1) % UART_VIEW_MAX_REC;
 101:uartTestMenu.c ****     }
 102:uartTestMenu.c **** 
 103:uartTestMenu.c ****     strncpy(g_recBuf[writeIdx], line, UART_VIEW_REC_LEN - 1);
 104:uartTestMenu.c ****     g_recBuf[writeIdx][UART_VIEW_REC_LEN - 1] = '\0';
 105:uartTestMenu.c ****     g_recvCount++;
 106:uartTestMenu.c **** 
 107:uartTestMenu.c ****     if (g_autoScroll)
 108:uartTestMenu.c ****     {
 109:uartTestMenu.c ****         uint16 totalLines = calcTotalLines();
 110:uartTestMenu.c ****         uint16 visLines   = getVisibleLines();
 111:uartTestMenu.c ****         g_scrollLine = (totalLines > visLines)
 112:uartTestMenu.c ****                        ? (int16)(totalLines - visLines) : 0;
 113:uartTestMenu.c ****     }
 114:uartTestMenu.c ****     g_bNeedRedraw = TRUE;
 115:uartTestMenu.c **** }
 116:uartTestMenu.c **** 
 117:uartTestMenu.c **** /* ================================================================
 118:uartTestMenu.c ****  * uartTestDrawScreen — LCD 뷰어 화면 그리기
 119:uartTestMenu.c ****  *
 120:uartTestMenu.c ****  *  [y:  0 ~  39]        헤더: 타이틀 + 수신 카운트
 121:uartTestMenu.c ****  *  [y: 40 ~ (H-40)]    바디: 수신 문자열
 122:uartTestMenu.c ****  *  [y: (H-40) ~ H]     푸터: [UP] [DOWN] [CLEAR]
 123:uartTestMenu.c ****  * ================================================================ */
 124:uartTestMenu.c **** static void uartTestDrawScreen(void)
 125:uartTestMenu.c **** {
 126:uartTestMenu.c ****     if (!g_bNeedRedraw) return;
 127:uartTestMenu.c ****     g_bNeedRedraw = FALSE;
 128:uartTestMenu.c **** 
 129:uartTestMenu.c ****     uint16 screenW    = g_SCREEN_WIDTH;
 130:uartTestMenu.c ****     uint16 screenH    = g_SCREEN_HEIGHT;
 131:uartTestMenu.c ****     uint16 bodyTop    = UART_VIEW_HEADER_H;
 132:uartTestMenu.c ****     uint16 bodyBottom = screenH - UART_VIEW_FOOTER_H;
 133:uartTestMenu.c ****     uint16 cpl        = getCharsPerLine();
 134:uartTestMenu.c ****     uint16 visLines   = getVisibleLines();
 135:uartTestMenu.c **** 
 136:uartTestMenu.c ****     /* 헤더 */
 137:uartTestMenu.c ****     FillRectangle(0, 0, screenW, bodyTop, VIEW_HDR_BG);
 138:uartTestMenu.c ****     LCD_printf(4, 14, WHITE, VIEW_HDR_BG, Font8x16,
 139:uartTestMenu.c ****                "EMBROIDERY UART RX TEST  [%u]", g_recvCount);
 140:uartTestMenu.c **** 
 141:uartTestMenu.c ****     /* 바디 배경 */
 142:uartTestMenu.c ****     FillRectangle(0, bodyTop, screenW, bodyBottom, BLACK);
 143:uartTestMenu.c **** 
 144:uartTestMenu.c ****     /* 텍스트 렌더링 */
 145:uartTestMenu.c ****     int16  absLine  = 0;
 146:uartTestMenu.c ****     uint16 dispLine = 0;
 147:uartTestMenu.c ****     char   lineBuf[41];
 148:uartTestMenu.c ****     uint8  r;
 149:uartTestMenu.c **** 
 150:uartTestMenu.c ****     for (r = 0; r < g_recCount && dispLine < visLines; r++)
 151:uartTestMenu.c ****     {
 152:uartTestMenu.c ****         uint8  idx = (g_recHead + r) % UART_VIEW_MAX_REC;
 153:uartTestMenu.c ****         uint16 len = (uint16)strlen(g_recBuf[idx]);
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccyutung.s 			page 7


 154:uartTestMenu.c ****         if (len == 0) len = 1;
 155:uartTestMenu.c **** 
 156:uartTestMenu.c ****         uint16 pos = 0;
 157:uartTestMenu.c ****         while (pos < len && dispLine < visLines)
 158:uartTestMenu.c ****         {
 159:uartTestMenu.c ****             if (absLine >= g_scrollLine)
 160:uartTestMenu.c ****             {
 161:uartTestMenu.c ****                 uint16 copyLen = len - pos;
 162:uartTestMenu.c ****                 if (copyLen > cpl) copyLen = cpl;
 163:uartTestMenu.c ****                 memcpy(lineBuf, g_recBuf[idx] + pos, copyLen);
 164:uartTestMenu.c ****                 lineBuf[copyLen] = '\0';
 165:uartTestMenu.c **** 
 166:uartTestMenu.c ****                 uint16 y = bodyTop + dispLine * UART_VIEW_LINE_H + 1;
 167:uartTestMenu.c ****                 LCD_printf(0, y, WHITE, BLACK, Font8x16, "%s", lineBuf);
 168:uartTestMenu.c ****                 dispLine++;
 169:uartTestMenu.c ****             }
 170:uartTestMenu.c ****             pos    += cpl;
 171:uartTestMenu.c ****             absLine++;
 172:uartTestMenu.c ****         }
 173:uartTestMenu.c ****         if (len == 1 && g_recBuf[idx][0] == '\0') absLine++;
 174:uartTestMenu.c ****     }
 175:uartTestMenu.c **** 
 176:uartTestMenu.c ****     /* 푸터: QUIT / UP / DOWN / CLEAR (4등분) */
 177:uartTestMenu.c ****     {
 178:uartTestMenu.c ****         uint16 btnY  = bodyBottom;
 179:uartTestMenu.c ****         uint16 bw    = screenW / 4;          /* 버튼 1개 너비 */
 180:uartTestMenu.c ****         COLOR  clrQuit  = CONVERT565( 20, 100,  20);
 181:uartTestMenu.c ****         COLOR  clrClear = CONVERT565(100,  20,  20);
 182:uartTestMenu.c **** 
 183:uartTestMenu.c ****         FillRectangle(0,          btnY, bw     - 1, screenH, clrQuit);
 184:uartTestMenu.c ****         FillRectangle(bw      + 1, btnY, bw * 2 - 1, screenH, VIEW_BTN_BG);
 185:uartTestMenu.c ****         FillRectangle(bw * 2 + 1, btnY, bw * 3 - 1, screenH, VIEW_BTN_BG);
 186:uartTestMenu.c ****         FillRectangle(bw * 3 + 1, btnY, screenW,     screenH, clrClear);
 187:uartTestMenu.c **** 
 188:uartTestMenu.c ****         LCD_printf(bw / 2 - 16,           btnY + 14, WHITE, clrQuit,    Font8x16, "QUIT");
 189:uartTestMenu.c ****         LCD_printf(bw + bw / 2 - 8,       btnY + 14, WHITE, VIEW_BTN_BG, Font8x16, "UP");
 190:uartTestMenu.c ****         LCD_printf(bw * 2 + bw / 2 - 16,  btnY + 14, WHITE, VIEW_BTN_BG, Font8x16, "DOWN");
 191:uartTestMenu.c ****         LCD_printf(bw * 3 + bw / 2 - 20,  btnY + 14, WHITE, clrClear,   Font8x16, "CLEAR");
 192:uartTestMenu.c ****     }
 193:uartTestMenu.c **** }
 194:uartTestMenu.c **** 
