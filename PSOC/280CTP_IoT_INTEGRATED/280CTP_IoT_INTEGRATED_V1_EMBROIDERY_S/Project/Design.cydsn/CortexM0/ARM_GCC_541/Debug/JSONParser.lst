  39:jsmn-master/jsmn.h **** /**
  40:jsmn-master/jsmn.h ****  * JSON type identifier. Basic types are:
  41:jsmn-master/jsmn.h ****  * 	o Object
  42:jsmn-master/jsmn.h ****  * 	o Array
  43:jsmn-master/jsmn.h ****  * 	o String
  44:jsmn-master/jsmn.h ****  * 	o Other primitive: number, boolean (true/false) or null
  45:jsmn-master/jsmn.h ****  */
  46:jsmn-master/jsmn.h **** typedef enum {
  47:jsmn-master/jsmn.h ****   JSMN_UNDEFINED = 0,
  48:jsmn-master/jsmn.h ****   JSMN_OBJECT = 1,
  49:jsmn-master/jsmn.h ****   JSMN_ARRAY = 2,
  50:jsmn-master/jsmn.h ****   JSMN_STRING = 3,
  51:jsmn-master/jsmn.h ****   JSMN_PRIMITIVE = 4
  52:jsmn-master/jsmn.h **** } jsmntype_t;
  53:jsmn-master/jsmn.h **** 
  54:jsmn-master/jsmn.h **** enum jsmnerr {
  55:jsmn-master/jsmn.h ****   /* Not enough tokens were provided */
  56:jsmn-master/jsmn.h ****   JSMN_ERROR_NOMEM = -1,
  57:jsmn-master/jsmn.h ****   /* Invalid character inside JSON string */
  58:jsmn-master/jsmn.h ****   JSMN_ERROR_INVAL = -2,
  59:jsmn-master/jsmn.h ****   /* The string is not a full JSON packet, more bytes expected */
  60:jsmn-master/jsmn.h ****   JSMN_ERROR_PART = -3
  61:jsmn-master/jsmn.h **** };
  62:jsmn-master/jsmn.h **** 
  63:jsmn-master/jsmn.h **** /**
  64:jsmn-master/jsmn.h ****  * JSON token description.
  65:jsmn-master/jsmn.h ****  * type		type (object, array, string etc.)
  66:jsmn-master/jsmn.h ****  * start	start position in JSON data string
  67:jsmn-master/jsmn.h ****  * end		end position in JSON data string
  68:jsmn-master/jsmn.h ****  */
  69:jsmn-master/jsmn.h **** typedef struct jsmntok {
  70:jsmn-master/jsmn.h ****   jsmntype_t type;
  71:jsmn-master/jsmn.h ****   int start;
  72:jsmn-master/jsmn.h ****   int end;
  73:jsmn-master/jsmn.h ****   int size;
  74:jsmn-master/jsmn.h **** #ifdef JSMN_PARENT_LINKS
  75:jsmn-master/jsmn.h ****   int parent;
  76:jsmn-master/jsmn.h **** #endif
  77:jsmn-master/jsmn.h **** } jsmntok_t;
  78:jsmn-master/jsmn.h **** 
  79:jsmn-master/jsmn.h **** /**
  80:jsmn-master/jsmn.h ****  * JSON parser. Contains an array of token blocks available. Also stores
  81:jsmn-master/jsmn.h ****  * the string being parsed now and current position in that string.
  82:jsmn-master/jsmn.h ****  */
  83:jsmn-master/jsmn.h **** typedef struct jsmn_parser {
  84:jsmn-master/jsmn.h ****   unsigned int pos;     /* offset in the JSON string */
  85:jsmn-master/jsmn.h ****   unsigned int toknext; /* next token to allocate */
  86:jsmn-master/jsmn.h ****   int toksuper;         /* superior token node, e.g. parent object or array */
  87:jsmn-master/jsmn.h **** } jsmn_parser;
