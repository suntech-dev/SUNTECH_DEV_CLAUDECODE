 422:lib/manageMenu.c ****             {                
 423:lib/manageMenu.c ****                 //strcpy(menu.title,thisMenu->nodeName);
 424:lib/manageMenu.c ****                 EraseBlankArea(GetBodyArea().top,FALSE);                  
