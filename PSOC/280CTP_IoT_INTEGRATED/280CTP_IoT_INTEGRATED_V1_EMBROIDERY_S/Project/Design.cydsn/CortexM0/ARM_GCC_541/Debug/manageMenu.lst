 288:lib/manageMenu.c **** int doDisplayDir(void *this, uint8 reflash) ///////////////////////////////////////////////////////
 289:lib/manageMenu.c **** /////////////////////////////////////////////////////////////////////////////////////////////////
 290:lib/manageMenu.c **** {    
 291:lib/manageMenu.c ****     MENUNODE *thisMenu = (MENUNODE *) this;    
 292:lib/manageMenu.c **** 
 293:lib/manageMenu.c ****     static char *listText[] = {"PORTRAIT", "LANDSCAPE"};
 294:lib/manageMenu.c ****     static uint16 indexSelect = 0;
 295:lib/manageMenu.c ****     static uint16 page = 0, oldIndexSelect;
 296:lib/manageMenu.c ****     
 297:lib/manageMenu.c ****     if(reflash)
 298:lib/manageMenu.c ****     {         
 299:lib/manageMenu.c ****         oldIndexSelect = indexSelect = (getMiscConfig()->bDisplayDir == DISPLAY_DIRECTION_PORTRAIT)
 300:lib/manageMenu.c ****     }
 301:lib/manageMenu.c ****     
 302:lib/manageMenu.c ****     switch(doSelectList(this, reflash, listText, 2, &indexSelect, &page))
 303:lib/manageMenu.c ****     {
 304:lib/manageMenu.c ****         case 0:
 305:lib/manageMenu.c ****         case 1:
 306:lib/manageMenu.c ****             setDisplayDirection((indexSelect==1) ? DISPLAY_DIRECTION_PORTRAIT : DISPLAY_DIRECTION_L
 307:lib/manageMenu.c ****             doSelectList(this, TRUE, listText, 2, &indexSelect, &page);
 308:lib/manageMenu.c ****             break; 
 309:lib/manageMenu.c ****         case MENU_BOTTOM_LEFT: // QUIT
 310:lib/manageMenu.c ****         {            
 311:lib/manageMenu.c ****             setDisplayDirection((oldIndexSelect==1) ? DISPLAY_DIRECTION_PORTRAIT : DISPLAY_DIRECTIO
 312:lib/manageMenu.c ****             return MENU_RETURN_PARENT;
 313:lib/manageMenu.c ****         }
 314:lib/manageMenu.c ****         case MENU_BOTTOM_RIGHT: // SAVE
 315:lib/manageMenu.c ****         {
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccgrDMxt.s 			page 7


 316:lib/manageMenu.c ****             ShowWaitMessage();                                    
 317:lib/manageMenu.c ****             SaveExternalFlashConfig();
 318:lib/manageMenu.c ****             return MENU_RETURN_PARENT;
 319:lib/manageMenu.c ****         }            
 320:lib/manageMenu.c ****     }
 321:lib/manageMenu.c ****     return MENU_RETURN_THIS;    
 322:lib/manageMenu.c **** }
