 444:lib/manageMenu.c ****                     {
 445:lib/manageMenu.c ****                         char c =  message[i];
 446:lib/manageMenu.c ****                       //  printf("%c",c);
 447:lib/manageMenu.c ****                         if(c == ' ' || c == '\r' || c == '\n') continue;
 448:lib/manageMenu.c **** 
