  26:lib/menu.c    **** MENUNODE * createMENUNODE(MENUNODE *parent, char *nodeName, int (*func)(void *this, uint8 reflash))
  27:lib/menu.c    **** {
  28:lib/menu.c    ****     static uint16 index=0;
  29:lib/menu.c    ****     
  30:lib/menu.c    ****     if(index >= MAX_MENU_NODE)
  31:lib/menu.c    ****     {
  32:lib/menu.c    ****         printf("MENU BODE Out of Memory : [%d]\r\n", index);
  33:lib/menu.c    ****         return NULL;
  34:lib/menu.c    ****     }
  35:lib/menu.c    ****     
  36:lib/menu.c    ****     MENUNODE *node = &g_MENUNODE[index++];
  37:lib/menu.c    ****     
  38:lib/menu.c    ****     node->parent       = parent;
  39:lib/menu.c    ****     node->func         = func;
  40:lib/menu.c    ****     node->firstChild   = NULL;
