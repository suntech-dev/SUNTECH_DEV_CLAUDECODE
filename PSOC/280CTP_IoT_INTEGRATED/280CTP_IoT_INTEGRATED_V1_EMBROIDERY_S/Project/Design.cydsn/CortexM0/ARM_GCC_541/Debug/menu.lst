  42:lib/menu.c    ****     strcpy(node->nodeName,nodeName);
  43:lib/menu.c    ****     
  44:lib/menu.c    ****     if(parent != NULL) addMENUNODE(parent,node);
  45:lib/menu.c    ****     
  46:lib/menu.c    ****     return node;
  47:lib/menu.c    **** }
