  31:lib/stdout.c  **** FILE __stdin = {STDIN_HANDLE};
  32:lib/stdout.c  **** FILE __stdout = {STDOUT_HANDLE};
  33:lib/stdout.c  **** FILE __stderr = {STDERR_HANDLE};
  34:lib/stdout.c  **** 
  35:lib/stdout.c  **** int fputc(int ch, FILE *file) 
  36:lib/stdout.c  **** {
  37:lib/stdout.c  ****     int ret = EOF;
  38:lib/stdout.c  **** 
  39:lib/stdout.c  ****     switch( file->handle )
  40:lib/stdout.c  ****     {
  41:lib/stdout.c  ****         case STDOUT_HANDLE:
  42:lib/stdout.c  ****             UART_UartPutChar(ch);
  43:lib/stdout.c  ****             ret = ch ;
  44:lib/stdout.c  ****             break ;
  45:lib/stdout.c  **** 
  46:lib/stdout.c  ****         case STDERR_HANDLE:
  47:lib/stdout.c  ****             ret = ch ;
  48:lib/stdout.c  ****             break ;
  49:lib/stdout.c  **** 
  50:lib/stdout.c  ****         default:
  51:lib/stdout.c  ****             file = file;
  52:lib/stdout.c  ****             break ;
  53:lib/stdout.c  ****     }
  54:lib/stdout.c  ****     return ret ;
  55:lib/stdout.c  **** }
  56:lib/stdout.c  **** 
  57:lib/stdout.c  **** #elif defined (__ICCARM__)      /* IAR */
  58:lib/stdout.c  **** 
  59:lib/stdout.c  **** /* For IAR compiler revise __write() function for printf functionality */
  60:lib/stdout.c  **** size_t __write(int handle, const unsigned char * buffer, size_t size)
  61:lib/stdout.c  **** {
  62:lib/stdout.c  ****     size_t nChars = 0;
  63:lib/stdout.c  **** 
  64:lib/stdout.c  ****     if (buffer == 0)
  65:lib/stdout.c  ****     {
  66:lib/stdout.c  ****         /*
  67:lib/stdout.c  ****          * This means that we should flush internal buffers.  Since we
  68:lib/stdout.c  ****          * don't we just return.  (Remember, "handle" == -1 means that all
  69:lib/stdout.c  ****          * handles should be flushed.)
  70:lib/stdout.c  ****          */
  71:lib/stdout.c  ****         return (0);
  72:lib/stdout.c  ****     }
  73:lib/stdout.c  **** 
  74:lib/stdout.c  ****     for (/* Empty */; size != 0; --size)
  75:lib/stdout.c  ****     {
  76:lib/stdout.c  ****         UART_UartPutChar(*buffer++);
  77:lib/stdout.c  ****         ++nChars;
  78:lib/stdout.c  ****     }
  79:lib/stdout.c  **** 
  80:lib/stdout.c  ****     return (nChars);
  81:lib/stdout.c  **** }
  82:lib/stdout.c  **** 
