 271:lib/widget.c  **** /////////////////////////////////////////////////////////////////////////////////////////////////
 272:lib/widget.c  **** int doListMenu(void *this, uint8 reflash) ///////////////////////////////////////////////////////
 273:lib/widget.c  **** /////////////////////////////////////////////////////////////////////////////////////////////////
 274:lib/widget.c  **** {    
 275:lib/widget.c  ****     MENUNODE *thisMenu = (MENUNODE *) this;     
 276:lib/widget.c  ****     static uint16 noOfList;
 277:lib/widget.c  **** 
 278:lib/widget.c  ****     switch(reflash)
 279:lib/widget.c  ****     {
 280:lib/widget.c  ****         case TRUE: // 화면이 바뀔때 실행
 281:lib/widget.c  ****             {
 282:lib/widget.c  ****                 noOfList = getNoOfChild(thisMenu);
 283:lib/widget.c  ****                 g_ListMenu.curPage = 0;
 284:lib/widget.c  ****                 SetDrawNodeListButtons(thisMenu, &g_ListMenu);
 285:lib/widget.c  ****                 UpdateDrawListButtons(&g_ListMenu,NO_SELECT);
 286:lib/widget.c  ****                 SetDrawBottomButtons("QUIT", NULL, BUTTON_STYLE_R_GREEN, BUTTON_STYLE_R_BLUE); 
 287:lib/widget.c  ****             //    printf("Start Page : %d\r\n",page);
 288:lib/widget.c  ****             }
 289:lib/widget.c  ****             break;  
 290:lib/widget.c  ****         
 291:lib/widget.c  ****         case FALSE: // Cliking Check
 292:lib/widget.c  ****             {
 293:lib/widget.c  ****                 TOUCH tc = GetTouch();
 294:lib/widget.c  ****                 if(tc.isClick == FALSE) break;
 295:lib/widget.c  ****                 
 296:lib/widget.c  ****                 uint16 idx = getIndexOfClickedListMenu(&tc, &g_ListMenu);
 297:lib/widget.c  ****                 
 298:lib/widget.c  ****                 switch(idx)
 299:lib/widget.c  ****                 {
 300:lib/widget.c  ****                     case IDX_SCROLL_UP:   g_ListMenu.curPage--;
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccsOrxbJ.s 			page 17


