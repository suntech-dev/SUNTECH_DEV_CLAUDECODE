 210:lib/widget.c  **** void UpdateDrawListButtons(LIST_MENU *menu, uint16 indexSelect)
 211:lib/widget.c  **** {
 212:lib/widget.c  ****     RECT bodyRect = GetBodyArea();
 213:lib/widget.c  ****     uint16 yPos = bodyRect.top;
 214:lib/widget.c  ****         
 215:lib/widget.c  ****     for(int i=0; i < menu->noOfDisplayButton; i++)
 216:lib/widget.c  ****     {                        
 217:lib/widget.c  ****         int j = i+menu->curPage*menu->noOfDisplayButton;
 218:lib/widget.c  ****         if(j >= menu->sizeOfList) break;
 219:lib/widget.c  **** 
 220:lib/widget.c  ****         BUTTON *btn = &menu->btns[i];
 221:lib/widget.c  **** 
 222:lib/widget.c  ****         if(indexSelect != NO_SELECT)
 223:lib/widget.c  ****         {
 224:lib/widget.c  ****             char buff[MAX_BUTTON_TEXT_SIZE];
 225:lib/widget.c  ****             sprintf(buff,"%c%s",(indexSelect==j) ? '>' : ' ',menu->listText[j]);
 226:lib/widget.c  ****             strcpy(btn->text,buff);
 227:lib/widget.c  ****         } else {
 228:lib/widget.c  ****            strcpy(btn->text,menu->listText[j]); 
 229:lib/widget.c  ****         }
 230:lib/widget.c  ****         
 231:lib/widget.c  ****         DrawButton(btn);
 232:lib/widget.c  ****         yPos = btn->rect.bottom + 1;
 233:lib/widget.c  ****     }
 234:lib/widget.c  ****     
 235:lib/widget.c  ****     EraseBlankArea(yPos, isExistScroll(menu));
 236:lib/widget.c  **** }
