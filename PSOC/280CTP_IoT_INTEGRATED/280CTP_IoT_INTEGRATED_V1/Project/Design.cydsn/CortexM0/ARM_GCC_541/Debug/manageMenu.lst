 367:lib/manageMenu.c **** int doFactoryReset(void *this, uint8 reflash)
 368:lib/manageMenu.c **** {
 369:lib/manageMenu.c ****     MENUNODE *thisMenu = (MENUNODE *) this;
 370:lib/manageMenu.c ****     static YES_NO_MENU menu;   
 371:lib/manageMenu.c ****     
 372:lib/manageMenu.c ****     switch(reflash)
 373:lib/manageMenu.c ****     {
 374:lib/manageMenu.c ****         case TRUE: // 화면이 바뀔때 실행
 375:lib/manageMenu.c ****             {                
 376:lib/manageMenu.c ****                 strcpy(menu.title,thisMenu->nodeName);
 377:lib/manageMenu.c ****                 SetDrawYesNoButtons(&menu, "Do you want ?");
 378:lib/manageMenu.c ****                 
 379:lib/manageMenu.c ****                 SetDrawBottomButtons("QUIT", "YES", BUTTON_STYLE_R_GREEN, BUTTON_STYLE_R_BLUE);  
 380:lib/manageMenu.c ****             }
 381:lib/manageMenu.c ****             break;  
 382:lib/manageMenu.c ****         
 383:lib/manageMenu.c ****         case FALSE: // Cliking Check
 384:lib/manageMenu.c ****             {
 385:lib/manageMenu.c **** 
 386:lib/manageMenu.c ****                 TOUCH tc = GetTouch();
 387:lib/manageMenu.c ****                 if(tc.isClick == FALSE) break;
 388:lib/manageMenu.c **** 
 389:lib/manageMenu.c ****                 switch(getIndexOfClickedButton(&tc,g_btnBottom,2))
 390:lib/manageMenu.c ****                 {
 391:lib/manageMenu.c ****                     case BOTTOM_LEFT:
 392:lib/manageMenu.c ****                     {
 393:lib/manageMenu.c ****                         return MENU_RETURN_PARENT;
 394:lib/manageMenu.c ****                     }
 395:lib/manageMenu.c ****                     case BOTTOM_RIGHT: 
 396:lib/manageMenu.c ****                     {
 397:lib/manageMenu.c ****                         ShowMessage("Reset..");
 398:lib/manageMenu.c ****                         W25qxx_EraseChip();
 399:lib/manageMenu.c ****                         ResetInternalFlash();
 400:lib/manageMenu.c ****                         CySoftwareReset();
 401:lib/manageMenu.c ****                         return MENU_RETURN_PARENT;                                
 402:lib/manageMenu.c ****                     }                            
 403:lib/manageMenu.c ****                 }
 404:lib/manageMenu.c ****                                
 405:lib/manageMenu.c ****             }
 406:lib/manageMenu.c ****             break;
 407:lib/manageMenu.c ****     }
 408:lib/manageMenu.c ****     return MENU_RETURN_THIS;    
 409:lib/manageMenu.c **** }
