  84:andonMenu.c   **** char * updateDateTime(uint8 reflash)
  85:andonMenu.c   **** {
  86:andonMenu.c   ****     static uint32 uOldtSeconds = 0, bToggle=TRUE;
  87:andonMenu.c   ****     static char strTime[10];
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\cc2MKiJf.s 			page 3


  88:andonMenu.c   ****     uint32 time = RTC_GetTime();
  89:andonMenu.c   ****     
  90:andonMenu.c   ****     uint32 uSeconds = RTC_GetSecond(time);
  91:andonMenu.c   ****         
  92:andonMenu.c   ****     if(uOldtSeconds != uSeconds || reflash == TRUE)
  93:andonMenu.c   ****     {    
  94:andonMenu.c   ****         uOldtSeconds = uSeconds;        
  95:andonMenu.c   ****   
  96:andonMenu.c   ****         if(bToggle) 
  97:andonMenu.c   ****         {
  98:andonMenu.c   ****             bToggle = FALSE;
  99:andonMenu.c   ****             sprintf(strTime, "%02lu:%02lu", RTC_GetHours(time), RTC_GetMinutes(time)); 
 100:andonMenu.c   ****         }
 101:andonMenu.c   ****         else
 102:andonMenu.c   ****         {
 103:andonMenu.c   ****             bToggle = TRUE;
 104:andonMenu.c   ****             sprintf(strTime, "%02lu %02lu", RTC_GetHours(time), RTC_GetMinutes(time)); 
 105:andonMenu.c   ****         }
 106:andonMenu.c   ****         return strTime;
 107:andonMenu.c   ****     }
 108:andonMenu.c   ****     return NULL;
 109:andonMenu.c   **** }
