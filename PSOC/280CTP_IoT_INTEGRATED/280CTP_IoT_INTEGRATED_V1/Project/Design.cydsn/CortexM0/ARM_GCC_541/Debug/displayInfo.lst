  31:displayInfo.c **** void DisplayData()
  32:displayInfo.c **** {        
  33:displayInfo.c ****     for(int i=0; i < 3; i++)
  34:displayInfo.c ****     {
  35:displayInfo.c ****         BUTTON *btn = &Values[i];
  36:displayInfo.c **** 
  37:displayInfo.c ****         btn->fontType = FONT_ArialNumFontPlus32x50;
  38:displayInfo.c ****         
  39:displayInfo.c ****         btn->Align = TEXT_ALIGN_RIGHT;
  40:displayInfo.c ****         btn->backgroundColor = BLACK;
  41:displayInfo.c ****         RECT *r = &btn->rect;
  42:displayInfo.c ****         
  43:displayInfo.c ****         r->left = SCREEN_WIDTH / 2;
  44:displayInfo.c ****         r->right = SCREEN_WIDTH    - rightMargin-5;
  45:displayInfo.c ****         r->top   = ButtonHeight * i;
  46:displayInfo.c ****         r->bottom = r->top + ButtonHeight - 1;                 
  47:displayInfo.c ****     }
  48:displayInfo.c ****     sprintf(Values[0].text,"%d", g_WorkingData.target);
  49:displayInfo.c ****     Values[0].foregroundColor = YELLOW;  
  50:displayInfo.c ****     
  51:displayInfo.c ****     sprintf(Values[1].text,"%d", g_WorkingData.actualCount);
  52:displayInfo.c ****     Values[1].foregroundColor = GREEN;    
  53:displayInfo.c ****     
  54:displayInfo.c ****     sprintf(Values[2].text,"%d", g_WorkingData.actualCount*100/g_WorkingData.target);  
  55:displayInfo.c ****     Values[2].foregroundColor = ORANGE;
  56:displayInfo.c ****     
  57:displayInfo.c ****     DrawButton(&Values[0]);
  58:displayInfo.c ****     // for Drawing Button
  59:displayInfo.c ****     g_bUpdateTrimCount = TRUE;
  60:displayInfo.c ****     UpdateActualCount();
  61:displayInfo.c ****     LCD_DrawFont(Values[2].rect.right+2,Values[2].rect.top+34, Values[2].foregroundColor = ORANGE, 
