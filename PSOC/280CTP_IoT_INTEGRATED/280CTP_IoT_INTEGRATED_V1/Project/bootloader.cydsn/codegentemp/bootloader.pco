# bootloader
# 2026-03-10 06:51:47Z

# IO_4@[IOP=(0)][IoId=(4)] is reserved: KhzXtalEnabled
dont_use_io iocell 0 4
# IO_5@[IOP=(0)][IoId=(5)] is reserved: KhzXtalEnabled
dont_use_io iocell 0 5
set_location "ClockGenBlock" m0s8clockgenblockcell -1 -1 0
set_location "ClockBlock" m0s8clockblockcell -1 -1 0
set_location "\USBFS:Dp\" logicalport -1 -1 13
set_io "\USBFS:Dp(0)\" iocell 13 0
set_io "\USBFS:Dm(0)\" iocell 13 1
set_io "LED(0)" iocell 0 1
set_io "LCD_SS(0)" iocell 2 4
set_io "LCD_SCL(0)" iocell 2 2
set_io "LCD_MOSI(0)" iocell 2 0
set_io "LCD_Backlight(0)" iocell 1 6
set_io "LCD_MISO(0)" iocell 2 1
set_io "LCD_RES(0)" iocell 2 6
set_io "LCD_RS(0)" iocell 2 5
set_location "\SPIM_LCD:BSPIM:load_rx_data\" 0 0 1 1
set_location "\SPIM_LCD:BSPIM:tx_status_0\" 0 0 0 3
set_location "\SPIM_LCD:BSPIM:tx_status_4\" 0 0 1 3
set_location "\SPIM_LCD:BSPIM:rx_status_6\" 1 0 0 2
set_location "\USBFS:high_int\" interrupt -1 -1 30
set_location "\USBFS:med_int\" interrupt -1 -1 0
set_location "\USBFS:lo_int\" interrupt -1 -1 31
set_location "\USBFS:dp_int\" interrupt -1 -1 5
set_location "\USBFS:cy_m0s8_usb\" p4usbcell -1 -1 0
set_location "\SPIM_LCD:BSPIM:BitCounter\" 1 1 7
set_location "\SPIM_LCD:BSPIM:TxStsReg\" 0 0 4
set_location "\SPIM_LCD:BSPIM:RxStsReg\" 1 0 4
set_location "\SPIM_LCD:BSPIM:sR8:Dp:u0\" 1 1 2
set_location "\Ctrl_LCD_RS:Sync:ctrl_reg\" 1 0 6
set_location "Net_184" 1 0 1 3
set_location "Net_185" 1 1 1 1
set_location "\SPIM_LCD:BSPIM:state_2\" 0 0 1 0
set_location "\SPIM_LCD:BSPIM:state_1\" 1 0 0 0
set_location "\SPIM_LCD:BSPIM:state_0\" 0 0 0 1
set_location "\SPIM_LCD:BSPIM:load_cond\" 0 1 0 1
set_location "\SPIM_LCD:BSPIM:ld_ident\" 1 1 0 3
set_location "\SPIM_LCD:BSPIM:cnt_enable\" 1 1 0 2
set_location "Net_186" 1 0 1 1
