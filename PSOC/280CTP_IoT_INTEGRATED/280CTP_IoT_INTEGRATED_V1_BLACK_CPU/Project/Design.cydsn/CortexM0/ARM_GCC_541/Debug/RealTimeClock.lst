  19:lib/RealTimeClock.c **** /* Time: 02:59:50 */
  20:lib/RealTimeClock.c **** #define TIME_HOUR           (0x02u)
  21:lib/RealTimeClock.c **** #define TIME_MIN            (0x59u)
  22:lib/RealTimeClock.c **** #define TIME_SEC            (0x50u)
  23:lib/RealTimeClock.c **** #define HOUR_OFFSET         (16u)
  24:lib/RealTimeClock.c **** #define MIN_OFFSET          (8u)
  25:lib/RealTimeClock.c **** #define TIME_HR_MIN_SEC     ((uint32)(TIME_HOUR << HOUR_OFFSET) | \
  26:lib/RealTimeClock.c ****                             (uint32)(TIME_MIN << MIN_OFFSET)    | \
  27:lib/RealTimeClock.c ****                              TIME_SEC)
  28:lib/RealTimeClock.c **** /* Date: 03/22/2014 */
  29:lib/RealTimeClock.c **** #define DATE_MONTH          (RTC_MARCH)
  30:lib/RealTimeClock.c **** #define DATE_DAY            (0x22u)
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccLOgOY2.s 			page 2


