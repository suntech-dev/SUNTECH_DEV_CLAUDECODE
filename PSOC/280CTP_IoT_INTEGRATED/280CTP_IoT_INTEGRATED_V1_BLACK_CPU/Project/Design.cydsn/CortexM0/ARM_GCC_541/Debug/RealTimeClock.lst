  42:lib/RealTimeClock.c **** // 1s에 관련된 것들  ///////////////////////////////////////////////
  43:lib/RealTimeClock.c **** ///////////////////////////////////////////////////////////////
  44:lib/RealTimeClock.c **** uint8 g_uNoSecondCounter=0;
  45:lib/RealTimeClock.c **** TIMER_COUNTER g_timerCounter_1s[MAX_NO_SECOND_COUNTER];
  46:lib/RealTimeClock.c **** 
  47:lib/RealTimeClock.c **** // 1s counter를 다시 시작한다
  48:lib/RealTimeClock.c **** void resetCounter_1s(uint16 index)
  49:lib/RealTimeClock.c **** {
  50:lib/RealTimeClock.c ****     g_timerCounter_1s[index].current = g_timerCounter_1s[index].max;
  51:lib/RealTimeClock.c **** }
  52:lib/RealTimeClock.c **** 
  53:lib/RealTimeClock.c **** // 1ms count의 목표에 도달 했는지 여부, index는 ONE_MILISECOND_COUNTER enum값
  54:lib/RealTimeClock.c **** // 주의 : main loop의 총 수행시간이 1s 보다 크면 목표값에 도달한 것을 놓칠 
  55:lib/RealTimeClock.c **** uint8 isFinishCounter_1s(uint16 index) 
  56:lib/RealTimeClock.c **** {    
  57:lib/RealTimeClock.c ****     if(g_timerCounter_1s[index].current == 0)
  58:lib/RealTimeClock.c ****     {
  59:lib/RealTimeClock.c ****         resetCounter_1s(index);
  60:lib/RealTimeClock.c ****         return TRUE;
  61:lib/RealTimeClock.c ****     }
  62:lib/RealTimeClock.c ****     return FALSE;
  63:lib/RealTimeClock.c **** }
  64:lib/RealTimeClock.c **** 
  65:lib/RealTimeClock.c **** // 1s timer counter 등록 
  66:lib/RealTimeClock.c **** uint8 registerCounter_1s(uint16 maxCount)
  67:lib/RealTimeClock.c **** {
  68:lib/RealTimeClock.c ****     if(g_uNoSecondCounter < MAX_NO_SECOND_COUNTER-1)
  69:lib/RealTimeClock.c ****     {
  70:lib/RealTimeClock.c ****         g_timerCounter_1s[g_uNoSecondCounter].current = 
  71:lib/RealTimeClock.c ****         g_timerCounter_1s[g_uNoSecondCounter].max = maxCount;
  72:lib/RealTimeClock.c ****         
  73:lib/RealTimeClock.c ****         return g_uNoSecondCounter++;
  74:lib/RealTimeClock.c ****     } else {
  75:lib/RealTimeClock.c ****         printf("Warning : resisterCounter_1s()\r\n"); 
  76:lib/RealTimeClock.c ****     }
  77:lib/RealTimeClock.c ****     return 0xFF;   
  78:lib/RealTimeClock.c **** }
  79:lib/RealTimeClock.c **** 
  80:lib/RealTimeClock.c **** // 현재 counter 값을 알아낸다. 
  81:lib/RealTimeClock.c **** // 주의 counter is Decreasing..
  82:lib/RealTimeClock.c **** uint16 getCurrentTimerCounter_1s(uint8 index) { return g_timerCounter_1s[index].current; }
