  33:lib/RealTimeClock.c **** #define DAY_OFFSET          (16u)
  34:lib/RealTimeClock.c **** #define DATE_MONTH_DAY_YEAR ((uint32)(DATE_MONTH << MONTH_OFFSET)   | \
