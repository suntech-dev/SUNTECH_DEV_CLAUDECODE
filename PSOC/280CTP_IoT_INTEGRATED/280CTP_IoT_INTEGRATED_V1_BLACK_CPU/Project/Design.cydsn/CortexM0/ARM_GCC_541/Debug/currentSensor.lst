 176:currentSensor.c **** 
 177:currentSensor.c ****     switch(reflash)
 178:currentSensor.c ****     {
 179:currentSensor.c ****         case TRUE: // ĒÖöļ®┤ņØ┤ ļ░öļĆöļĢī ņŗżĒ¢ē
 180:currentSensor.c ****             {
 181:currentSensor.c ****                 g_ListMenu.curPage = page;
 182:currentSensor.c ****                 SetDrawListButtons(&g_ListMenu,thisMenu->nodeName,NULL,0, BUTTON_STYLE_LIST);
 183:currentSensor.c **** 
 184:currentSensor.c ****                 SetDrawBottomButtons("QUIT", "SET", BUTTON_STYLE_R_GREEN, BUTTON_STYLE_R_BLUE); 
 185:currentSensor.c ****                 
