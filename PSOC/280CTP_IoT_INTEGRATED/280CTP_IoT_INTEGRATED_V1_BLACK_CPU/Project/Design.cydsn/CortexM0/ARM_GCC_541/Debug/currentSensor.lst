 219:currentSensor.c ****                             ShowWaitMessage();
 220:currentSensor.c ****                             SaveExternalFlashConfig();                                
 221:currentSensor.c ****                         }
 222:currentSensor.c ****                         return MENU_RETURN_PARENT;
 223:currentSensor.c ****                     }
 224:currentSensor.c ****                 }      
 225:currentSensor.c ****             }
 226:currentSensor.c ****             break;
 227:currentSensor.c ****     }
 228:currentSensor.c ****     
 229:currentSensor.c ****     currTime = RTC_GetUnixTime();
 230:currentSensor.c ****     if(currTime != oldTime)
 231:currentSensor.c ****     {
