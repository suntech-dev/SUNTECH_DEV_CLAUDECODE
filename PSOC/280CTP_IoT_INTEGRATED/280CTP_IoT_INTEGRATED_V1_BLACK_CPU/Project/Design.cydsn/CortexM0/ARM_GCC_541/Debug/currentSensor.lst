 191:currentSensor.c ****                 average = 0;
 192:currentSensor.c ****                 
 193:currentSensor.c ****                 oldTime = RTC_GetUnixTime();
 194:currentSensor.c ****             }
 195:currentSensor.c ****             break;  
 196:currentSensor.c ****         
 197:currentSensor.c ****         case FALSE: // Cliking Check
 198:currentSensor.c ****             {
 199:currentSensor.c ****                 TOUCH tc = GetTouch();
 200:currentSensor.c **** 
 201:currentSensor.c ****                 if(tc.isClick == FALSE) break;
 202:currentSensor.c ****                 
 203:currentSensor.c ****                 int ret = getIndexOfClickedButton(&tc,g_btnBottom,2);             
 204:currentSensor.c ****                 switch(ret)
 205:currentSensor.c ****                 {
 206:currentSensor.c ****                     case BOTTOM_LEFT:
 207:currentSensor.c ****                     case BOTTOM_RIGHT:                     
 208:currentSensor.c ****                     {
 209:currentSensor.c ****                         page = g_ListMenu.curPage;
 210:currentSensor.c ****                         
 211:currentSensor.c ****                         if(g_ptrMachineParameter->current_enable==FALSE)
