 170:currentSensor.c **** /////////////////////////////////////////////////////////////////////////////////////////////////
 171:currentSensor.c **** {    
 172:currentSensor.c ****     MENUNODE *thisMenu = (MENUNODE *) this;
 173:currentSensor.c ****     static uint16 page = 0;
 174:currentSensor.c ****     static int16 min, max, average;
