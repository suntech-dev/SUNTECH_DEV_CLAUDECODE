  84:andonMenu.c   **** char * updateDateTime(uint8 reflash)
  85:andonMenu.c   **** {
  86:andonMenu.c   ****     static uint32 uOldtSeconds = 0, bToggle=TRUE;
  87:andonMenu.c   ****     static char strTime[10];
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccVgSZhb.s 			page 3


  88:andonMenu.c   ****     uint32 time = RTC_GetTime();
  89:andonMenu.c   ****     
  90:andonMenu.c   ****     uint32 uSeconds = RTC_GetSecond(time);
  91:andonMenu.c   ****         
  92:andonMenu.c   ****     if(uOldtSeconds != uSeconds || reflash == TRUE)
  93:andonMenu.c   ****     {    
  94:andonMenu.c   ****         uOldtSeconds = uSeconds;        
  95:andonMenu.c   ****   
  96:andonMenu.c   ****         if(bToggle) 
  97:andonMenu.c   ****         {
  98:andonMenu.c   ****             bToggle = FALSE;
