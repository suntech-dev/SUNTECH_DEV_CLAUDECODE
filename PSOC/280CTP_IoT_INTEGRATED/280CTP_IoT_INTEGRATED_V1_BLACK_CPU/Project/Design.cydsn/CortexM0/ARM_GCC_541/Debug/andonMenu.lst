  31:andonMenu.c   **** */
  32:andonMenu.c   **** {
  33:andonMenu.c   ****     RECT bodyRect = GetBodyArea();
  34:andonMenu.c   ****     uint16 yPos = bodyRect.top;
  35:andonMenu.c   ****     uint16 yPosTitle;
  36:andonMenu.c   **** 
  37:andonMenu.c   ****     menu->noOfDisplayButton = getMaxNoOfItemInListButton();
  38:andonMenu.c   **** 
  39:andonMenu.c   ****     if(title != NULL) menu->noOfDisplayButton--;
  40:andonMenu.c   ****    
  41:andonMenu.c   ****     menu->sizeOfList = list->noOfList;
  42:andonMenu.c   ****     strcpy(menu->title,title);
  43:andonMenu.c   **** 
  44:andonMenu.c   ****     uint8 withScroll = isExistScroll(menu);
