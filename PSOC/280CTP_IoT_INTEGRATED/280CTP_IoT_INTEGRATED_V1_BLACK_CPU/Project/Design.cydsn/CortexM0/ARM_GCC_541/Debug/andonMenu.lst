  59:andonMenu.c   ****         int16 not_completed_qty = item->not_completed_qty;
  60:andonMenu.c   ****         
  61:andonMenu.c   ****         if(not_completed_qty == 0)
  62:andonMenu.c   ****             SetButtonStyleColor(btn, BUTTON_STYLE_LIST); 
  63:andonMenu.c   ****         else
  64:andonMenu.c   ****             ////SetButtonStyleColor(btn, BUTTON_STYLE_R_ORANGE); 
  65:andonMenu.c   ****             SetButtonStyleColor(btn, BUTTON_STYLE_R_RED);
  66:andonMenu.c   ****             
  67:andonMenu.c   ****         btn->align = TEXT_ALIGN_LEFT;
  68:andonMenu.c   ****             
  69:andonMenu.c   ****         if(getMiscConfig()->bDisplayDir == DISPLAY_DIRECTION_PORTRAIT)
  70:andonMenu.c   ****         {
  71:andonMenu.c   ****             sprintf(menu->listText[i],"%-10s %2d",item->text, item->not_completed_qty);
  72:andonMenu.c   ****         }
  73:andonMenu.c   ****         else
  74:andonMenu.c   ****         {
  75:andonMenu.c   ****             sprintf(menu->listText[i],"%-15s %2d",item->text, item->not_completed_qty);
  76:andonMenu.c   ****         }
  77:andonMenu.c   ****                 
  78:andonMenu.c   ****         yPos += g_DEFAULT_BUTTON_HEIGHT;
  79:andonMenu.c   ****     }
  80:andonMenu.c   **** 
  81:andonMenu.c   ****     if(withScroll) SetDrawScrollButton(menu);
  82:andonMenu.c   **** }
