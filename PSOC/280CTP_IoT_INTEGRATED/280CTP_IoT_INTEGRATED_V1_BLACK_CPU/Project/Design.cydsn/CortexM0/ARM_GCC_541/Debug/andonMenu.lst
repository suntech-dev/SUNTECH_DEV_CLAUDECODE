 111:andonMenu.c   **** int doAndonMenu(void *this, uint8 reflash)
 112:andonMenu.c   **** {   
 113:andonMenu.c   ****     static uint16 page = 0;
 114:andonMenu.c   ****     char *strTime = updateDateTime(reflash);
 115:andonMenu.c   ****     
 116:andonMenu.c   ****    // static LIST_MENU menu;
 117:andonMenu.c   ****     
 118:andonMenu.c   ****     if(g_AndonLists.bUpdated || reflash == TRUE)
 119:andonMenu.c   ****     {
 120:andonMenu.c   ****         SetAndonListButtons(&g_ListMenu, NULL, &g_AndonLists);
 121:andonMenu.c   ****         UpdateDrawListButtons(&g_ListMenu,NO_SELECT);
 122:andonMenu.c   ****         g_AndonLists.bUpdated = FALSE;
 123:andonMenu.c   ****     }
 124:andonMenu.c   ****     
 125:andonMenu.c   ****     if(strTime != NULL)
 126:andonMenu.c   ****     {
 127:andonMenu.c   ****         BUTTON *rightButton = &g_btnBottom[1];
 128:andonMenu.c   ****         SetButtonText(rightButton,strTime);
 129:andonMenu.c   ****         DrawButton(rightButton);
 130:andonMenu.c   ****     }
 131:andonMenu.c   ****     switch(reflash)
 132:andonMenu.c   ****     {
 133:andonMenu.c   ****         case TRUE: // 화면이 바뀔때 실행
 134:andonMenu.c   ****         {
 135:andonMenu.c   ****            SetDrawBottomButtons("QUIT", strTime, BUTTON_STYLE_R_GREEN, BUTTON_STYLE_WHITE); 
 136:andonMenu.c   ****            getCount()->andonEntry = TRUE;
 137:andonMenu.c   ****            SaveInternalFlash();
 138:andonMenu.c   ****            g_ListMenu.curPage = page;
 139:andonMenu.c   ****          //  SaveInternalFlash();
 140:andonMenu.c   ****         }
 141:andonMenu.c   ****         break;  
 142:andonMenu.c   ****         
 143:andonMenu.c   ****         case FALSE: // Cliking Check
 144:andonMenu.c   ****             {
ARM GAS  C:\Users\luvsd\AppData\Local\Temp\ccVgSZhb.s 			page 4


 145:andonMenu.c   ****                 TOUCH tc = GetTouch();
 146:andonMenu.c   ****                 if(tc.isClick == FALSE) break;
 147:andonMenu.c   ****                 
 148:andonMenu.c   ****                 uint16 idx = getIndexOfClickedListMenu(&tc, &g_ListMenu);
 149:andonMenu.c   **** 
 150:andonMenu.c   ****                 switch(idx)
 151:andonMenu.c   ****                 {
 152:andonMenu.c   ****                     case IDX_SCROLL_UP:   g_ListMenu.curPage--;
 153:andonMenu.c   ****                           UpdateDrawListButtons(&g_ListMenu,NO_SELECT);
 154:andonMenu.c   ****                         break;
 155:andonMenu.c   ****                     case IDX_SCROLL_DOWN: g_ListMenu.curPage++;
 156:andonMenu.c   ****                           UpdateDrawListButtons(&g_ListMenu,NO_SELECT);                   
 157:andonMenu.c   ****                         break;
 158:andonMenu.c   ****                     case NO_CLICK :
 159:andonMenu.c   ****                         {
 160:andonMenu.c   ****                             switch(getIndexOfClickedButton(&tc,g_btnBottom,2))
 161:andonMenu.c   ****                             {
 162:andonMenu.c   ****                                 case BOTTOM_LEFT: 
 163:andonMenu.c   ****                                    getCount()->andonEntry = FALSE;
 164:andonMenu.c   ****                                    SaveInternalFlash();
 165:andonMenu.c   ****                                 page = g_ListMenu.curPage;
 166:andonMenu.c   ****                                 return MENU_RETURN_PARENT;
 167:andonMenu.c   ****                             //  case BOTTOM_RIGHT: return 1;                            
 168:andonMenu.c   ****                             }
 169:andonMenu.c   ****                             break;
 170:andonMenu.c   ****                         }
 171:andonMenu.c   ****                     default: 
 172:andonMenu.c   ****                         if(idx < g_ListMenu.sizeOfList) 
 173:andonMenu.c   ****                         {
 174:andonMenu.c   ****                             g_AndonLists.uSelectIndex = idx;
 175:andonMenu.c   ****                             return 0;
 176:andonMenu.c   ****                         }
 177:andonMenu.c   ****                 }        
 178:andonMenu.c   ****             }
 179:andonMenu.c   ****             break;
 180:andonMenu.c   ****     }
 181:andonMenu.c   ****         
 182:andonMenu.c   ****     return MENU_RETURN_THIS;    
 183:andonMenu.c   **** }
