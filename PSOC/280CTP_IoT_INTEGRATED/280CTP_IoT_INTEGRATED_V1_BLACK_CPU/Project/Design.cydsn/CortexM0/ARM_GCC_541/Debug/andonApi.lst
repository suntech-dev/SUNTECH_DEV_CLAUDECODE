  38:andonApi.c    **** uint8 andonLoop()
  39:andonApi.c    **** {
  40:andonApi.c    ****     if(!isEmptyQueueANDON())
  41:andonApi.c    ****     {
  42:andonApi.c    ****         ANDON_QUEUE *aq = deQueueANDON();
  43:andonApi.c    ****         
  44:andonApi.c    ****         char url[512];
  45:andonApi.c    ****         snprintf(url, sizeof(url), "%s?code=%s", DEFAULT_API_ENDPOINT, aq->message);
  46:andonApi.c    **** 
  47:andonApi.c    ****         g_uAndonRequestType = aq->type;
  48:andonApi.c    **** 
  49:andonApi.c    ****         wifi_cmd_http(url);
  50:andonApi.c    ****         
  51:andonApi.c    ****         return TRUE;
  52:andonApi.c    ****     }
  53:andonApi.c    ****     
  54:andonApi.c    ****     if(g_bReceivedAndonStart)
  55:andonApi.c    ****     {
  56:andonApi.c    ****         if(isFinishCounter_1ms(g_index_request_interval)) // Wifi Strength 체크를 5sec마다 수
  57:andonApi.c    ****         {
  58:andonApi.c    ****             resetCounter_1ms(g_index_request_interval);
  59:andonApi.c    ****             
  60:andonApi.c    ****             if(g_ptrMachineParameter->andon_enable==TRUE) makeAndonList();             
  61:andonApi.c    ****             
  62:andonApi.c    ****             return TRUE;
  63:andonApi.c    ****         }
  64:andonApi.c    ****         
  65:andonApi.c    ****         WarningLight();
  66:andonApi.c    ****     }
  67:andonApi.c    ****    
  68:andonApi.c    ****     return FALSE;
  69:andonApi.c    **** }
