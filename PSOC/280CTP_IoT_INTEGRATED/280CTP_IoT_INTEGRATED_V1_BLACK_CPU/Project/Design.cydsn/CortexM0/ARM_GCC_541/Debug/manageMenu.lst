 411:lib/manageMenu.c **** int doMonitoring(void *this, uint8 reflash)
 412:lib/manageMenu.c **** {
 413:lib/manageMenu.c ****     MENUNODE *thisMenu = (MENUNODE *) this;
 414:lib/manageMenu.c ****     static uint16 x, y=0;
 415:lib/manageMenu.c ****     static char message[200];
 416:lib/manageMenu.c ****     static int16 indexString;
 417:lib/manageMenu.c ****     
 418:lib/manageMenu.c ****     switch(reflash)
 419:lib/manageMenu.c ****     {
 420:lib/manageMenu.c ****         case TRUE: // 화면이 바뀔때 실행
 421:lib/manageMenu.c ****             {                
 422:lib/manageMenu.c ****                 //strcpy(menu.title,thisMenu->nodeName);
 423:lib/manageMenu.c ****                 EraseBlankArea(GetBodyArea().top,FALSE);                  
