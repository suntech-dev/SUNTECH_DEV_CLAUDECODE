 425:lib/manageMenu.c ****                 x = 0;
 426:lib/manageMenu.c ****                 y = GetBodyArea().top;
 427:lib/manageMenu.c ****                 indexString = 0;
 428:lib/manageMenu.c ****             }
 429:lib/manageMenu.c ****             break;  
 430:lib/manageMenu.c ****         
 431:lib/manageMenu.c ****         case FALSE: // Cliking Check
 432:lib/manageMenu.c ****             {
 433:lib/manageMenu.c ****                 while(UART_SpiUartGetRxBufferSize() > 0 )
 434:lib/manageMenu.c ****                 {
 435:lib/manageMenu.c ****                     char c = UART_UartGetChar();
