 316:lib/manageMenu.c ****             SaveExternalFlashConfig();
 317:lib/manageMenu.c ****             return MENU_RETURN_PARENT;
 318:lib/manageMenu.c ****         }            
 319:lib/manageMenu.c ****     }
 320:lib/manageMenu.c ****     return MENU_RETURN_THIS;    
 321:lib/manageMenu.c **** }
