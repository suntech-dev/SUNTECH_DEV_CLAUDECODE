 287:lib/manageMenu.c **** int doDisplayDir(void *this, uint8 reflash) ///////////////////////////////////////////////////////
 288:lib/manageMenu.c **** /////////////////////////////////////////////////////////////////////////////////////////////////
 289:lib/manageMenu.c **** {    
 290:lib/manageMenu.c ****     MENUNODE *thisMenu = (MENUNODE *) this;    
 291:lib/manageMenu.c **** 
 292:lib/manageMenu.c ****     static char *listText[] = {"PORTRAIT", "LANDSCAPE"};
 293:lib/manageMenu.c ****     static uint16 indexSelect = 0;
 294:lib/manageMenu.c ****     static uint16 page = 0, oldIndexSelect;
 295:lib/manageMenu.c ****     
 296:lib/manageMenu.c ****     if(reflash)
 297:lib/manageMenu.c ****     {         
 298:lib/manageMenu.c ****         oldIndexSelect = indexSelect = (getMiscConfig()->bDisplayDir == DISPLAY_DIRECTION_PORTRAIT)
 299:lib/manageMenu.c ****     }
 300:lib/manageMenu.c ****     
 301:lib/manageMenu.c ****     switch(doSelectList(this, reflash, listText, 2, &indexSelect, &page))
 302:lib/manageMenu.c ****     {
 303:lib/manageMenu.c ****         case 0:
 304:lib/manageMenu.c ****         case 1:
 305:lib/manageMenu.c ****             setDisplayDirection((indexSelect==1) ? DISPLAY_DIRECTION_PORTRAIT : DISPLAY_DIRECTION_L
 306:lib/manageMenu.c ****             doSelectList(this, TRUE, listText, 2, &indexSelect, &page);
 307:lib/manageMenu.c ****             break; 
 308:lib/manageMenu.c ****         case MENU_BOTTOM_LEFT: // QUIT
 309:lib/manageMenu.c ****         {            
 310:lib/manageMenu.c ****             setDisplayDirection((oldIndexSelect==1) ? DISPLAY_DIRECTION_PORTRAIT : DISPLAY_DIRECTIO
 311:lib/manageMenu.c ****             return MENU_RETURN_PARENT;
 312:lib/manageMenu.c ****         }
 313:lib/manageMenu.c ****         case MENU_BOTTOM_RIGHT: // SAVE
 314:lib/manageMenu.c ****         {
 315:lib/manageMenu.c ****             ShowWaitMessage();                                    
