 374:Generated_Source\PSoC4/Bootloader.c **** *  \brief
 375:Generated_Source\PSoC4/Bootloader.c **** *     This computes a 16-bit checksum for the provided number of bytes contained
 376:Generated_Source\PSoC4/Bootloader.c **** *     in the provided buffer.
 377:Generated_Source\PSoC4/Bootloader.c **** *
 378:Generated_Source\PSoC4/Bootloader.c **** *  \param buffer
 379:Generated_Source\PSoC4/Bootloader.c **** *     The buffer containing the data to compute the checksum.
 380:Generated_Source\PSoC4/Bootloader.c **** *  \param size
 381:Generated_Source\PSoC4/Bootloader.c **** *     The number of bytes in the buffer to compute the checksum.
 382:Generated_Source\PSoC4/Bootloader.c **** *
 383:Generated_Source\PSoC4/Bootloader.c **** *  \return 
 384:Generated_Source\PSoC4/Bootloader.c **** *     A 16-bit checksum for the provided data.
 385:Generated_Source\PSoC4/Bootloader.c **** *
 386:Generated_Source\PSoC4/Bootloader.c **** *  \endinternal
 387:Generated_Source\PSoC4/Bootloader.c **** *******************************************************************************/
 388:Generated_Source\PSoC4/Bootloader.c **** static uint16 Bootloader_CalcPacketChecksum(const uint8 buffer[], uint16 size) \
 389:Generated_Source\PSoC4/Bootloader.c ****                     CYSMALL 
 390:Generated_Source\PSoC4/Bootloader.c **** {
 391:Generated_Source\PSoC4/Bootloader.c ****     #if(0u != Bootloader_PACKET_CHECKSUM_CRC)
 392:Generated_Source\PSoC4/Bootloader.c **** 
 393:Generated_Source\PSoC4/Bootloader.c ****         uint16 CYDATA crc = Bootloader_CRC_CCITT_INITIAL_VALUE;
 394:Generated_Source\PSoC4/Bootloader.c ****         uint16 CYDATA tmp;
 395:Generated_Source\PSoC4/Bootloader.c ****         uint8  CYDATA i;
 396:Generated_Source\PSoC4/Bootloader.c ****         uint16 CYDATA tmpIndex = size;
 397:Generated_Source\PSoC4/Bootloader.c **** 
 398:Generated_Source\PSoC4/Bootloader.c ****         if(0u == size)
 399:Generated_Source\PSoC4/Bootloader.c ****         {
 400:Generated_Source\PSoC4/Bootloader.c ****             crc = ~crc;
 401:Generated_Source\PSoC4/Bootloader.c ****         }
 402:Generated_Source\PSoC4/Bootloader.c ****         else
 403:Generated_Source\PSoC4/Bootloader.c ****         {
 404:Generated_Source\PSoC4/Bootloader.c ****             do
 405:Generated_Source\PSoC4/Bootloader.c ****             {
 406:Generated_Source\PSoC4/Bootloader.c ****                 tmp = buffer[tmpIndex - size];
 407:Generated_Source\PSoC4/Bootloader.c **** 
 408:Generated_Source\PSoC4/Bootloader.c ****                 for (i = 0u; i < 8u; i++)
 409:Generated_Source\PSoC4/Bootloader.c ****                 {
 410:Generated_Source\PSoC4/Bootloader.c ****                     if (0u != ((crc & 0x0001u) ^ (tmp & 0x0001u)))
 411:Generated_Source\PSoC4/Bootloader.c ****                     {
 412:Generated_Source\PSoC4/Bootloader.c ****                         crc = (crc >> 1u) ^ Bootloader_CRC_CCITT_POLYNOMIAL;
 413:Generated_Source\PSoC4/Bootloader.c ****                     }
 414:Generated_Source\PSoC4/Bootloader.c ****                     else
 415:Generated_Source\PSoC4/Bootloader.c ****                     {
 416:Generated_Source\PSoC4/Bootloader.c ****                         crc >>= 1u;
 417:Generated_Source\PSoC4/Bootloader.c ****                     }
 418:Generated_Source\PSoC4/Bootloader.c **** 
 419:Generated_Source\PSoC4/Bootloader.c ****                     tmp >>= 1u;
 420:Generated_Source\PSoC4/Bootloader.c ****                 }
 421:Generated_Source\PSoC4/Bootloader.c **** 
 422:Generated_Source\PSoC4/Bootloader.c ****                 size--;
 423:Generated_Source\PSoC4/Bootloader.c ****             }
 424:Generated_Source\PSoC4/Bootloader.c ****             while(0u != size);
 425:Generated_Source\PSoC4/Bootloader.c **** 
 426:Generated_Source\PSoC4/Bootloader.c ****             crc = ~crc;
 427:Generated_Source\PSoC4/Bootloader.c ****             tmp = crc;
 428:Generated_Source\PSoC4/Bootloader.c ****             crc = ( uint16 )(crc << 8u) | (tmp >> 8u);
 429:Generated_Source\PSoC4/Bootloader.c ****         }
