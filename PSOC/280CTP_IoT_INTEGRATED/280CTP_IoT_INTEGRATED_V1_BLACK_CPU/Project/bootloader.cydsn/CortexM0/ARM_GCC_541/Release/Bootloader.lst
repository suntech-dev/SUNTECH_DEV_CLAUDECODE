 433:Generated_Source\PSoC4/Bootloader.c ****     #else
 434:Generated_Source\PSoC4/Bootloader.c **** 
 435:Generated_Source\PSoC4/Bootloader.c ****         uint16 CYDATA sum = 0u;
 436:Generated_Source\PSoC4/Bootloader.c **** 
 437:Generated_Source\PSoC4/Bootloader.c ****         while (size > 0u)
 438:Generated_Source\PSoC4/Bootloader.c ****         {
 439:Generated_Source\PSoC4/Bootloader.c ****             sum += buffer[size - 1u];
 440:Generated_Source\PSoC4/Bootloader.c ****             size--;
 441:Generated_Source\PSoC4/Bootloader.c ****         }
