{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Listen for Xdebug (Local - Laragon)",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "${workspaceFolder}": "${workspaceFolder}"
            }
        },
        {
            "name": "Listen for Xdebug (Remote - /var/www/html)",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "/var/www/html": "${workspaceFolder}"
            }
        }
    ]
}
